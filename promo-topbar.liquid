{%- comment -%}
  snippets/promo-topbar.liquid
  Luxury animated announcement bar — EternaScents
  - CSS-only infinite marquee, no JS required for animation
  - Visible on all screen sizes (replaces d-none d-md-block)
  - 3 configurable trust messages from theme settings
  - sessionStorage dismiss: closed for session, reopens next visit
  - Brand palette: gold #C9A646 on dark #071321
{%- endcomment -%}

{%- assign bar_bg    = settings.bgc_promo_topbar | default: '#071321' -%}
{%- assign bar_color = settings.color_content_promo_topbar | default: '#C9A646' -%}
{%- assign msg1      = settings.promo_msg_1 | default: 'Free UK Delivery on orders over £50' -%}
{%- assign msg2      = settings.promo_msg_2 | default: 'Free sample with every full bottle order' -%}
{%- assign msg3      = settings.promo_msg_3 | default: '100% Authentic Arabic Perfumes' -%}

<div
  class="es-announcement-bar"
  id="esAnnouncementBar"
  style="background-color: {{ bar_bg }}; color: {{ bar_color }};"
  data-bar-id="es-promo-bar-v1"
  role="region"
  aria-label="Announcement">

  <div class="es-announcement-bar__track" aria-hidden="true">
    <div class="es-announcement-bar__marquee">

      {%- comment -%} Content block — duplicated for seamless infinite loop {%- endcomment -%}
      {%- for i in (1..2) -%}
        <span class="es-announcement-bar__msg">
          <svg class="es-bar-icon" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path d="M8 16.5a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0zM15 16.5a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0z"/><path d="M3 4h-.75A.75.75 0 012 3.25V2.75A.75.75 0 012.75 2H4a1 1 0 01.98.804L5.25 5H17a1 1 0 01.98 1.196l-1.5 7A1 1 0 0115.5 14H6a1 1 0 01-.98-.804L3.72 5H3V4z"/></svg>
          {{ msg1 }}
        </span>
        <span class="es-announcement-bar__divider" aria-hidden="true">✦</span>

        <span class="es-announcement-bar__msg">
          <svg class="es-bar-icon" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M5 5a3 3 0 015-2.236A3 3 0 0114.83 6H16a2 2 0 110 4h-5V9a1 1 0 10-2 0v1H4a2 2 0 110-4h1.17A3.001 3.001 0 015 5zm4 1a1 1 0 10-2 0 1 1 0 002 0zm5 0a1 1 0 10-2 0 1 1 0 002 0zM4 11h12v6a2 2 0 01-2 2H6a2 2 0 01-2-2v-6z" clip-rule="evenodd"/></svg>
          {{ msg2 }}
        </span>
        <span class="es-announcement-bar__divider" aria-hidden="true">✦</span>

        <span class="es-announcement-bar__msg">
          <svg class="es-bar-icon" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
          {{ msg3 }}
        </span>
        <span class="es-announcement-bar__divider" aria-hidden="true">✦</span>
      {%- endfor -%}

    </div>
  </div>

  <button
    class="es-announcement-bar__close"
    id="esBarClose"
    aria-label="Close announcement"
    style="color: {{ bar_color }};">
    <svg viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <path d="M1 1l12 12M13 1L1 13"/>
    </svg>
  </button>

</div>

<style>
  .es-announcement-bar {
    position: relative;
    width: 100%;
    overflow: hidden;
    height: 40px;
    display: flex;
    align-items: center;
    z-index: 1000;
    /* No background-image — colour only for performance */
  }

  .es-announcement-bar.es-bar--hidden {
    display: none;
  }

  /* Track clips the scrolling content */
  .es-announcement-bar__track {
    flex: 1;
    overflow: hidden;
    height: 100%;
    display: flex;
    align-items: center;
    /* Fade edges for premium feel */
    -webkit-mask-image: linear-gradient(
      to right,
      transparent 0%,
      black 6%,
      black 94%,
      transparent 100%
    );
    mask-image: linear-gradient(
      to right,
      transparent 0%,
      black 6%,
      black 94%,
      transparent 100%
    );
  }

  /* Marquee container — width 200% holds original + duplicate */
  .es-announcement-bar__marquee {
    display: flex;
    align-items: center;
    white-space: nowrap;
    width: max-content;
    animation: es-marquee 28s linear infinite;
    gap: 0;
  }

  /* Pause on hover — reduces dizziness for slower readers */
  .es-announcement-bar:hover .es-announcement-bar__marquee {
    animation-play-state: paused;
  }

  @keyframes es-marquee {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  .es-announcement-bar__msg {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0 24px;
    white-space: nowrap;
  }

  .es-bar-icon {
    width: 14px;
    height: 14px;
    flex-shrink: 0;
    opacity: 0.85;
  }

  .es-announcement-bar__divider {
    font-size: 10px;
    opacity: 0.5;
    flex-shrink: 0;
    padding: 0 4px;
  }

  /* Close button */
  .es-announcement-bar__close {
    flex-shrink: 0;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0 14px;
    height: 100%;
    display: flex;
    align-items: center;
    opacity: 0.6;
    transition: opacity 0.2s;
  }

  .es-announcement-bar__close:hover {
    opacity: 1;
  }

  .es-announcement-bar__close svg {
    width: 10px;
    height: 10px;
  }

  /* Reduce motion — respect OS setting */
  @media (prefers-reduced-motion: reduce) {
    .es-announcement-bar__marquee {
      animation: none;
      justify-content: center;
    }
    /* Show only first set of messages when animation is off */
    .es-announcement-bar__marquee > *:nth-child(n+7) {
      display: none;
    }
  }

  /* Mobile — slightly smaller text, keep close button reachable */
  @media (max-width: 576px) {
    .es-announcement-bar {
      height: 36px;
    }
    .es-announcement-bar__msg {
      font-size: 11px;
      padding: 0 16px;
    }
  }
</style>

<script>
(function() {
  var BAR_KEY = 'es-bar-dismissed-v1';
  var bar     = document.getElementById('esAnnouncementBar');
  var closeBtn = document.getElementById('esBarClose');

  if (!bar) return;

  // Hide if dismissed this session
  if (sessionStorage.getItem(BAR_KEY)) {
    bar.classList.add('es-bar--hidden');
    return;
  }

  closeBtn && closeBtn.addEventListener('click', function() {
    bar.classList.add('es-bar--hidden');
    sessionStorage.setItem(BAR_KEY, '1');
  });
})();
</script>
