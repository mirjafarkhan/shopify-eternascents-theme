{%- comment -%}
  snippets/product-luxury.liquid — EternaScents Clean PDP
  Layout inspired by Zimaya / premium fragrance store style.

  Structure:
  ┌─────────────────────────────────────────────────────┐
  │ [Image card]      [Title, Price, Brand,             │
  │  Zoom icon        PayPal, Trust badges,             │
  │  Thumbnails]      Qty + ATC, SKU/Category]          │
  ├─────────────────────────────────────────────────────┤
  │ Description accordion (default open)                │
  │  → Description text                                 │
  │  → Fragrance Profile card (if notes exist)          │
  ├─────────────────────────────────────────────────────┤
  │ Additional Information accordion                    │
  ├─────────────────────────────────────────────────────┤
  │ Reviews accordion                                   │
  ├─────────────────────────────────────────────────────┤
  │ You May Also Like                                   │
  └─────────────────────────────────────────────────────┘

  JS compatibility kept:
  id="productSelect", id="Quantity", id="AddToCartForm"
  class="engoj-btn-addtocart", class="enj-product-price"
  class="enj-product-price-compare"
{%- endcomment -%}

{%- assign on_sale  = false -%}
{%- assign sold_out = false -%}
{%- if product.compare_at_price > product.price -%}{%- assign on_sale = true -%}{%- endif -%}
{%- unless product.available -%}{%- assign sold_out = true -%}{%- endunless -%}

{%- comment -%} Fragrance notes — metafields first, tag fallback {%- endcomment -%}
{%- assign mf         = product.metafields.fragrance -%}
{%- assign top_notes  = mf.top_notes   | default: '' -%}
{%- assign mid_notes  = mf.heart_notes | default: '' -%}
{%- assign base_notes = mf.base_notes  | default: '' -%}

{%- for tag in product.tags -%}
  {%- if tag contains 'top:'   and top_notes  == '' -%}{%- assign top_notes  = tag | remove: 'top:'   | strip -%}{%- endif -%}
  {%- if tag contains 'heart:' and mid_notes   == '' -%}{%- assign mid_notes  = tag | remove: 'heart:' | strip -%}{%- endif -%}
  {%- if tag contains 'base:'  and base_notes == '' -%}{%- assign base_notes = tag | remove: 'base:'  | strip -%}{%- endif -%}
{%- endfor -%}

{%- assign has_notes = false -%}
{%- if top_notes != '' or mid_notes != '' or base_notes != '' -%}{%- assign has_notes = true -%}{%- endif -%}

{%- comment -%} Inspired by tag {%- endcomment -%}
{%- assign inspired_by = '' -%}
{%- for tag in product.tags -%}
  {%- if tag contains 'inspired:' -%}{%- assign inspired_by = tag | remove: 'inspired:' | strip -%}{%- endif -%}
{%- endfor -%}

{%- comment -%} Delivery estimate {%- endcomment -%}
{%- assign today_hour = 'now' | date: '%H' | plus: 0 -%}
{%- if today_hour < 14 -%}{%- assign delivery_msg = 'Same-day dispatch if ordered before 2pm' -%}
{%- else -%}{%- assign delivery_msg = 'Next working day dispatch' -%}{%- endif -%}

{%- comment -%} Variant price for installment display {%- endcomment -%}
{%- assign inst_price = product.price | divided_by: 3 | money -%}

<!-------- BREADCRUMB -------->
<div class="zp-breadcrumb">
  <div class="zp-wrap">
    {%- render 'breadcrumb' -%}
  </div>
</div>

<!-------- HERO -------->
<section class="zp-hero">
  <div class="zp-wrap">
    <div class="zp-hero__grid">

      <!-------- GALLERY -------->
      <div class="zp-gallery">
        <div class="zp-gallery__main-card">
          <a
            href="{{ product.featured_image | image_url: 'master' }}"
            data-fancybox="zp-gallery"
            class="zp-gallery__zoom-btn"
            aria-label="Zoom image">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/><path d="M11 8v6M8 11h6"/></svg>
          </a>
          {%- if product.featured_image -%}
          <img
            id="zp-main-img"
            src="{{ product.featured_image | image_url: width: 800 }}"
            alt="{{ product.featured_image.alt | default: product.title | escape }}"
            width="800" height="800"
            loading="eager" fetchpriority="high"
            class="zp-gallery__main-img engoj_img_main">
          {%- endif -%}
        </div>

        {%- if product.images.size > 1 -%}
        <div class="zp-gallery__thumbs" id="zp-thumbs">
          {%- for image in product.images -%}
          <button
            type="button"
            class="zp-gallery__thumb{% if forloop.first %} zp-gallery__thumb--active{% endif %}"
            data-src="{{ image | image_url: width: 800 }}"
            data-full="{{ image | image_url: 'master' }}"
            data-alt="{{ image.alt | default: product.title | escape }}"
            aria-label="Image {{ forloop.index }}">
            <img src="{{ image | image_url: width: 120, height: 120, crop: 'center' }}" alt="" width="120" height="120" loading="lazy">
          </button>
          {%- endfor -%}
        </div>
        {%- endif -%}
      </div>
      <!-------- END GALLERY -------->

      <!-------- DETAILS -------->
      <div class="zp-details">

        <!---- Title ---->
        <h1 class="zp-details__title">{{ product.title }}</h1>

        <!---- Price ---->
        <div class="zp-details__price-row">
          <span class="zp-details__price enj-product-price">
            {%- if product.price_varies -%}From {%- endif -%}
            {{ product.price | money }}
          </span>
          {%- if on_sale -%}
          <span class="zp-details__price-old enj-product-price-compare">{{ product.compare_at_price | money }}</span>
          <span class="zp-details__save">Save {{ product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price }}%</span>
          {%- endif -%}
        </div>

        <!---- Brand ---->
        <p class="zp-details__vendor">{{ product.vendor }}</p>

        {%- if inspired_by != blank -%}
        <p class="zp-details__inspired">Inspired by <strong>{{ inspired_by }}</strong></p>
        {%- endif -%}

        <!---- Rating ---->
        {%- if section.settings.show_rating -%}
        <div class="zp-details__rating">
          <span class="shopify-product-reviews-badge" data-id="{{ product.id }}"></span>
        </div>
        {%- endif -%}

        <!---- PayPal installment ---->
        <div class="zp-details__paypal">
          <svg viewBox="0 0 24 24" fill="#003087" aria-hidden="true"><path d="M7.076 21.337H2.47a.641.641 0 0 1-.633-.74L4.944.901C5.026.382 5.474 0 5.998 0h7.46c2.57 0 4.578.543 5.69 1.81 1.01 1.15 1.304 2.42 1.012 4.287-.023.143-.047.288-.077.437-.983 5.05-4.349 6.797-8.647 6.797h-2.19c-.524 0-.968.382-1.05.9l-1.12 7.106z"/></svg>
          Pay in 3 × <strong>{{ inst_price }}</strong> interest-free with PayPal &amp; Klarna
        </div>

        <div class="zp-details__divider"></div>

        <!---- Trust badges ---->
        <div class="zp-trust">
          <div class="zp-trust__item">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/></svg>
            <span class="zp-trust__label">100% Authentic</span>
            <span class="zp-trust__sub">Guaranteed Genuine</span>
          </div>
          <div class="zp-trust__item">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"/></svg>
            <span class="zp-trust__label">Fast Dispatch</span>
            <span class="zp-trust__sub">{{ delivery_msg }}</span>
          </div>
          <div class="zp-trust__item">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 00-3.213-9.193 2.056 2.056 0 00-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 00-10.026 0 1.106 1.106 0 00-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12"/></svg>
            <span class="zp-trust__label">Secure Shipping</span>
            <span class="zp-trust__sub">Tracked UK Delivery</span>
          </div>
        </div>

        <div class="zp-details__divider"></div>

        <!---- Form ---->
        <form action="/cart/add" method="post" enctype="multipart/form-data" id="AddToCartForm" class="zp-form">

          <select name="id" id="productSelect" class="product-single__variants" style="display:none">
            {%- for variant in product.variants -%}
            {%- if variant.available -%}
            <option
              {%- if variant == product.selected_or_first_available_variant %} selected="selected"{%- endif -%}
              value="{{ variant.id }}" data-sku="{{ variant.sku }}">
              {{ variant.title }} — {{ variant.price | money }}
            </option>
            {%- else -%}
            <option disabled="disabled">{{ variant.title }} — {{ 'products.product.sold_out' | t }}</option>
            {%- endif -%}
            {%- endfor -%}
          </select>

          {%- if product.variants.size > 1 -%}
          <div class="zp-form__options proVariants">
            {%- for option in product.options -%}
              {%- render 'swatch' with option -%}
            {%- endfor -%}
          </div>
          {%- endif -%}

          <!---- Stock + variant label ---->
          <div class="zp-form__stock-row">
            <span class="zp-form__variant-title">{{ product.selected_or_first_available_variant.title | replace: 'Default Title', '' }}</span>
            {%- if sold_out -%}
            <span class="zp-form__stock zp-form__stock--out">Out of Stock</span>
            {%- else -%}
            <span class="zp-form__stock zp-form__stock--in">
              <svg viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><circle cx="8" cy="8" r="4"/></svg>
              In Stock
            </span>
            {%- endif -%}
          </div>

          <!---- Qty + ATC ---->
          {%- unless sold_out -%}
          <div class="zp-form__atc-row">
            <div class="zp-form__qty">
              <button type="button" class="zp-qty-btn zp-qty-minus" aria-label="Decrease">−</button>
              <input type="number" id="Quantity" name="quantity" value="1" min="1" class="zp-qty-input" aria-label="Quantity">
              <button type="button" class="zp-qty-btn zp-qty-plus" aria-label="Increase">+</button>
            </div>
            <button type="submit" name="add" class="zp-form__atc enj-add-to-cart-btn engoj-btn-addtocart">
              ADD TO CART
            </button>
          </div>

          <div class="zp-form__payment-btns">
            {%- form 'product', product -%}
              <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
              {{ form | payment_button }}
            {%- endform -%}
          </div>
          {%- else -%}
          <div class="zp-form__soldout">Currently Out of Stock</div>
          {%- endunless -%}

        </form>

        <!---- Meta info ---->
        <div class="zp-meta">
          {%- if section.settings.show_sku and product.selected_or_first_available_variant.sku != blank -%}
          <div class="zp-meta__row">
            <span class="zp-meta__key">SKU:</span>
            <span class="zp-meta__val engoj-variant-sku">{{ product.selected_or_first_available_variant.sku }}</span>
          </div>
          {%- endif -%}
          {%- if section.settings.show_cate and product.collections.size > 0 -%}
          <div class="zp-meta__row">
            <span class="zp-meta__key">Category:</span>
            <span class="zp-meta__val">
              {%- for col in product.collections limit: 2 -%}
                {%- unless col.handle == 'frontpage' or col.handle == 'all' -%}
                <a href="{{ col.url }}" class="zp-meta__link">{{ col.title }}</a>{% unless forloop.last %}, {% endunless %}
                {%- endunless -%}
              {%- endfor -%}
            </span>
          </div>
          {%- endif -%}
          <div class="zp-meta__row">
            <span class="zp-meta__key">Brand:</span>
            <span class="zp-meta__val">
              <a href="/collections/{{ product.vendor | handle }}" class="zp-meta__link zp-meta__link--bold">{{ product.vendor }}</a>
            </span>
          </div>
        </div>

        <!---- Wishlist + share ---->
        <div class="zp-details__actions">
          {%- render 'add-wishlist-pd' -%}
          {%- if section.settings.show_social_share -%}
            {%- render 'social_share-product' -%}
          {%- endif -%}
        </div>

      </div>
      <!-------- END DETAILS -------->

    </div>
  </div>
</section>

<!-------- ACCORDIONS -------->
<div class="zp-accordions">
  <div class="zp-wrap">

    <!---- Description (open by default) ---->
    <div class="zp-accord" id="zp-accord-desc">
      <button type="button" class="zp-accord__trigger is-open" aria-expanded="true">
        <span>Description</span>
        <span class="zp-accord__icon">
          <svg class="zp-accord__minus" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 10h10"/></svg>
          <svg class="zp-accord__plus" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M10 5v10M5 10h10"/></svg>
        </span>
      </button>
      <div class="zp-accord__panel is-open">

        {%- if product.description != blank -%}
        <div class="zp-accord__desc">{{ product.description }}</div>
        {%- endif -%}

        {%- if has_notes -%}
        <div class="zp-notes-card">
          <h3 class="zp-notes-card__title">Fragrance Profile</h3>
          <table class="zp-notes-card__table">
            {%- if top_notes != blank -%}
            <tr>
              <th>TOP NOTES:</th>
              <td>{{ top_notes }}</td>
            </tr>
            {%- endif -%}
            {%- if mid_notes != blank -%}
            <tr>
              <th>MIDDLE NOTES:</th>
              <td>{{ mid_notes }}</td>
            </tr>
            {%- endif -%}
            {%- if base_notes != blank -%}
            <tr>
              <th>BASE NOTES:</th>
              <td>{{ base_notes }}</td>
            </tr>
            {%- endif -%}
          </table>
        </div>
        {%- endif -%}

      </div>
    </div>

    <!---- Additional Information ---->
    <div class="zp-accord" id="zp-accord-info">
      <button type="button" class="zp-accord__trigger" aria-expanded="false">
        <span>Additional Information</span>
        <span class="zp-accord__icon">
          <svg class="zp-accord__minus" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 10h10"/></svg>
          <svg class="zp-accord__plus" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M10 5v10M5 10h10"/></svg>
        </span>
      </button>
      <div class="zp-accord__panel">
        <table class="zp-info-table">
          <tr><th>Brand</th><td>{{ product.vendor }}</td></tr>
          <tr><th>Type</th><td>Eau de Parfum</td></tr>
          {%- if product.selected_or_first_available_variant.sku != blank -%}
          <tr><th>SKU</th><td>{{ product.selected_or_first_available_variant.sku }}</td></tr>
          {%- endif -%}
          {%- for col in product.collections limit: 3 -%}
          {%- unless col.handle == 'frontpage' or col.handle == 'all' -%}
          <tr><th>Collection</th><td>{{ col.title }}</td></tr>
          {%- endunless -%}
          {%- endfor -%}
        </table>
      </div>
    </div>

    <!---- Delivery & Returns ---->
    <div class="zp-accord" id="zp-accord-delivery">
      <button type="button" class="zp-accord__trigger" aria-expanded="false">
        <span>Delivery &amp; Returns</span>
        <span class="zp-accord__icon">
          <svg class="zp-accord__minus" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 10h10"/></svg>
          <svg class="zp-accord__plus" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M10 5v10M5 10h10"/></svg>
        </span>
      </button>
      <div class="zp-accord__panel">
        <ul class="zp-delivery-list">
          <li><strong>Standard UK Delivery</strong> — 2–3 working days · FREE on orders over £50</li>
          <li><strong>Express UK Delivery</strong> — Next working day · £4.99 (order before 2pm)</li>
          <li><strong>International</strong> — 5–10 working days · from £8.99</li>
        </ul>
        <p>Returns accepted on sealed, unopened items within 30 days. Email <a href="mailto:returns@eternascents.com">returns@eternascents.com</a> to start a return.</p>
      </div>
    </div>

    <!---- Reviews ---->
    <div class="zp-accord" id="zp-accord-reviews">
      <button type="button" class="zp-accord__trigger" aria-expanded="false">
        <span>Reviews</span>
        <span class="zp-accord__icon">
          <svg class="zp-accord__minus" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 10h10"/></svg>
          <svg class="zp-accord__plus" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M10 5v10M5 10h10"/></svg>
        </span>
      </button>
      <div class="zp-accord__panel">
        <div id="shopify-product-reviews" data-id="{{ product.id }}">
          {{ product.metafields.spr.reviews }}
        </div>
      </div>
    </div>

  </div>
</div>

<!-------- YOU MAY ALSO LIKE -------->
<section class="zp-related">
  <div class="zp-wrap">
    <h2 class="zp-section-title">You May Also Like</h2>
    {%- assign current_handle = product.handle -%}
{%- assign found_collection = false -%}
{%- for col in product.collections -%}
  {%- if found_collection == false and col.handle != 'frontpage' and col.handle != 'all' and col.products_count > 1 -%}
    {%- assign found_collection = true -%}
    {%- assign related_col = col -%}
  {%- endif -%}
{%- endfor -%}

{%- if found_collection -%}
<div class="zp-related-grid">
  {%- for p in related_col.products limit: 5 -%}
    {%- unless p.handle == current_handle -%}
    <a href="{{ p.url }}" class="zp-related-card">
      <div class="zp-related-img">
        <img src="{{ p.featured_image | image_url: width: 400, height: 400, crop: 'center' }}"
             alt="{{ p.title | escape }}" width="400" height="400" loading="lazy">
      </div>
      <div class="zp-related-info">
        <p class="zp-related-name">{{ p.title | truncatewords: 6 }}</p>
        <p class="zp-related-price">{{ p.price | money }}</p>
      </div>
    </a>
    {%- endunless -%}
  {%- endfor -%}
</div>

<style>
.zp-related-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:16px}
.zp-related-card{text-decoration:none;border:1px solid #e8e8e8;border-radius:10px;overflow:hidden;background:#fff;transition:border-color .2s}
.zp-related-card:hover{border-color:#C9A646}
.zp-related-img{aspect-ratio:1/1;overflow:hidden;background:#f8f8f8}
.zp-related-img img{width:100%;height:100%;object-fit:contain;padding:12px;transition:transform .4s}
.zp-related-card:hover .zp-related-img img{transform:scale(1.05)}
.zp-related-info{padding:10px 12px}
.zp-related-name{font-size:12px;font-weight:600;color:#1a1a1a;margin:0 0 4px;line-height:1.3}
.zp-related-price{font-size:14px;font-weight:700;color:#C9A646;margin:0}
@media(max-width:600px){.zp-related-grid{grid-template-columns:repeat(2,1fr)}}
</style>
{%- endif -%}
  </div>
</section>

<!-------- STICKY ATC (mobile) -------->
{%- unless sold_out -%}
<div class="zp-sticky" id="zp-sticky" aria-hidden="true">
  <div class="zp-sticky__inner">
    <div>
      <p class="zp-sticky__title">{{ product.title | truncatewords: 5 }}</p>
      <p class="zp-sticky__price enj-product-price">{{ product.price | money }}</p>
    </div>
    <button type="button" class="zp-sticky__btn" onclick="document.querySelector('.engoj-btn-addtocart').click()">
      ADD TO CART
    </button>
  </div>
</div>
{%- endunless -%}

<!-------- CSS -------->
<style>
:root {
  --zp-gold:   #C9A646;
  --zp-dark:   #1a1a1a;
  --zp-muted:  #666;
  --zp-border: #e8e8e8;
  --zp-bg:     #f8f8f8;
  --zp-white:  #ffffff;
  --zp-radius: 12px;
}

.zp-wrap {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 24px;
}

.zp-section-title {
  font-size: 22px;
  font-weight: 600;
  color: var(--zp-dark);
  margin: 0 0 24px;
  letter-spacing: .01em;
}

/* ─── Breadcrumb ───────────────────────────── */
.zp-breadcrumb {
  padding: 14px 0;
  border-bottom: 1px solid var(--zp-border);
  font-size: 13px;
}

/* ─── Hero ─────────────────────────────────── */
.zp-hero {
  padding: 36px 0 48px;
}

.zp-hero__grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 56px;
  align-items: start;
}

/* ─── Gallery ──────────────────────────────── */
.zp-gallery__main-card {
  position: relative;
  background: var(--zp-white);
  border: 1px solid var(--zp-border);
  border-radius: var(--zp-radius);
  overflow: hidden;
  aspect-ratio: 1/1;
}

.zp-gallery__main-img {
  width: 100%;
  height: 100%;
  object-fit: contain;
  object-position: center;
  display: block;
  padding: 16px;
  transition: transform .5s ease;
}

.zp-gallery__main-card:hover .zp-gallery__main-img {
  transform: scale(1.04);
}

.zp-gallery__zoom-btn {
  position: absolute;
  top: 12px;
  right: 12px;
  z-index: 2;
  background: var(--zp-white);
  border: 1px solid var(--zp-border);
  border-radius: 50%;
  width: 36px;
  height: 36px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--zp-dark);
  transition: border-color .2s, color .2s;
  text-decoration: none;
}

.zp-gallery__zoom-btn:hover {
  border-color: var(--zp-gold);
