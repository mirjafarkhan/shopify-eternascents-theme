<!-------- JS -------->
<script>
(function() {

  /* Gallery thumb switcher */
  var mainImg = document.getElementById('zp-main-img');
  var thumbs  = document.getElementById('zp-thumbs');
  var zoomBtn = mainImg && mainImg.closest('a');

  if (thumbs && mainImg) {
    thumbs.addEventListener('click', function(e) {
      var btn = e.target.closest('.zp-gallery__thumb');
      if (!btn) return;
      thumbs.querySelectorAll('.zp-gallery__thumb').forEach(function(t) {
        t.classList.remove('zp-gallery__thumb--active');
      });
      btn.classList.add('zp-gallery__thumb--active');
      mainImg.src = btn.dataset.src;
      mainImg.alt = btn.dataset.alt;
      if (zoomBtn) zoomBtn.href = btn.dataset.full;
    });
  }

  /* Qty stepper */
  var qtyInput = document.getElementById('Quantity');
  document.addEventListener('click', function(e) {
    if (e.target.classList.contains('zp-qty-minus') && qtyInput) {
      qtyInput.value = Math.max(1, parseInt(qtyInput.value, 10) - 1);
    }
    if (e.target.classList.contains('zp-qty-plus') && qtyInput) {
      qtyInput.value = parseInt(qtyInput.value, 10) + 1;
    }
  });

  /* Accordions */
  document.querySelectorAll('.zp-accord__trigger').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var panel  = btn.nextElementSibling;
      var isOpen = btn.classList.contains('is-open');

      btn.classList.toggle('is-open', !isOpen);
      btn.setAttribute('aria-expanded', String(!isOpen));
      panel.classList.toggle('is-open', !isOpen);
    });
  });

  /* Sticky ATC */
  var sticky = document.getElementById('zp-sticky');
  var atcBtn = document.querySelector('.zp-form__atc');

  if (sticky && atcBtn && 'IntersectionObserver' in window) {
    new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        sticky.classList.toggle('is-visible', !entry.isIntersecting);
        sticky.setAttribute('aria-hidden', String(entry.isIntersecting));
      });
    }, { rootMargin: '-60px 0px 0px 0px' }).observe(atcBtn);
  }

})();
</script>
