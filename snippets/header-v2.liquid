{%- comment -%}
  snippets/header-v2.liquid — EternaScents redesigned header
  Layout:
  ┌────────────────────────────────────────────────────────┐
  │  [Logo]        [Search bar]          [Account  Cart]   │
  ├────────────────────────────────────────────────────────┤
  │        Home  ·  Collections  ·  Contact                │
  └────────────────────────────────────────────────────────┘
  - Sticky on scroll
  - White background / navy border-bottom
  - Keeps all theme JS hooks (js_height_hd, jsheader_sticky, js-call-minicart, js-call-popup-login)
{%- endcomment -%}

{%- comment -%}── HOMEPAGE ──{%- endcomment -%}
{% if section.settings.select_hds == "header_v2" %}
{% if template contains 'index' %}

<header id="header" class="es-hd header-v2-h2 js_height_hd jsheader_sticky d-none d-xl-block">

  {%- comment -%} Row 1: Logo | Search | Icons {%- endcomment -%}
  <div class="es-hd__top">
    <div class="container container-v1">
      <div class="es-hd__top-inner">

        {%- comment -%} Logo {%- endcomment -%}
        <div class="es-hd__logo">
          {% if section.settings.hd_home_logo_svg != blank %}
            <a href="{{ shop.url }}" class="es-hd__logo-link">{{ section.settings.hd_home_logo_svg }}</a>
          {% elsif section.settings.hd_home_logo != blank %}
            <a href="{{ shop.url }}" class="es-hd__logo-link">
              <img src="{{ section.settings.hd_home_logo | image_url }}"
                   width="{{ section.settings.hd_home_logo_maxwidth | default: 140 }}"
                   height="auto"
                   alt="{{ shop.name }}"
                   loading="eager">
            </a>
          {% else %}
            <a href="{{ shop.url }}" class="es-hd__logo-link es-hd__logo-text">{{ shop.name }}</a>
          {% endif %}
        </div>

        {%- comment -%} Search bar {%- endcomment -%}
        <div class="es-hd__search" id="es-hd-search-home">
          <form action="/search" method="get" role="search" class="es-hd__search-form">
            <input type="hidden" name="type" value="product">
            <input
              type="search"
              name="q"
              class="es-hd__search-input"
              placeholder="Search fragrances (e.g. oud, rose, amber)..."
              aria-label="Search fragrances"
              autocomplete="off"
            >
            <button type="submit" class="es-hd__search-btn" aria-label="Search">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            </button>
          </form>
          <div class="es-hd__suggestions" id="es-hd-suggestions-home"></div>
        </div>

        {%- comment -%} Icons: Account + Cart {%- endcomment -%}
        <div class="es-hd__icons">

          <a href="{% if customer %}/account{% else %}javascript:void(0){% endif %}"
             class="es-hd__icon-btn login {% unless customer %}js-call-popup-login{% endunless %}"
             aria-label="Account">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            <span class="es-hd__icon-label">Account</span>
          </a>

          <a href="javascript:void(0)" class="es-hd__icon-btn cart js-call-minicart" aria-label="Cart">
            <span class="es-hd__cart-wrap">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
              <span class="es-hd__cart-count js-number-cart number-cart {% if cart.item_count > 0 %}active{% endif %}">{{ cart.item_count }}</span>
            </span>
            <span class="es-hd__icon-label">Cart</span>
          </a>

        </div>
      </div>
    </div>
  </div>

  {%- comment -%} Row 2: Navigation {%- endcomment -%}
  <nav class="es-hd__nav" aria-label="Main navigation">
    <div class="container container-v1">
      <ul class="es-hd__nav-list">
        {%- assign nav_menu = section.settings.main_menu_store -%}
        {%- for link in linklists[nav_menu].links -%}
          <li class="es-hd__nav-item{% if link.links.size > 0 %} has-sub{% endif %}">
            <a href="{{ link.url }}" class="es-hd__nav-link{% if link.active %} active{% endif %}">
              {{- link.title -}}
              {%- if link.links.size > 0 -%}<svg class="es-hd__caret" width="10" height="10" viewBox="0 0 10 10" fill="currentColor"><path d="M5 6.5L1 2.5h8z"/></svg>{%- endif -%}
            </a>
            {%- if link.links.size > 0 -%}
              <ul class="es-hd__sub">
                {%- for child in link.links -%}
                  <li><a href="{{ child.url }}" class="es-hd__sub-link">{{ child.title }}</a></li>
                {%- endfor -%}
              </ul>
            {%- endif -%}
          </li>
        {%- endfor -%}
      </ul>
    </div>
  </nav>

</header>

<script>
jQuery(document).ready(function($) {
  {% if section.settings.enable_sticky_hd_home %}
  (function stickyHome() {
    var $nav = $('.jsheader_sticky');
    $(document).on('scroll', function() {
      $nav.toggleClass('menu_scroll_v2', $(this).scrollTop() > $nav.height());
    });
  })();
  {% endif %}
});
</script>

{% endif %}
{% endif %}


