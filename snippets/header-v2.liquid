<style>
/* ============================================================
   EternaScents Header v2 — redesigned
   ============================================================ */
@import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600&display=swap');

/* ── Outer header shell ── */
.es-hd {
  background: #fff;
  border-bottom: 1px solid #e8e0d0;
  position: relative;
  z-index: 999;
}

.es-hd.menu_scroll_v2 {
  position: fixed;
  top: 0; left: 0; right: 0;
  box-shadow: 0 2px 20px rgba(7,19,33,.10);
  animation: es-hd-drop .25s ease;
}

@keyframes es-hd-drop {
  from { transform: translateY(-100%); opacity: 0; }
  to   { transform: translateY(0);     opacity: 1; }
}

/* ── Row 1 ── */
.es-hd__top {
  padding: 12px 0;
  border-bottom: 1px solid #f0ebe0;
}

.es-hd__top-inner {
  display: flex;
  align-items: center;
  gap: 24px;
}

/* Logo */
.es-hd__logo { flex-shrink: 0; }

.es-hd__logo-link { display: block; line-height: 1; }

.es-hd__logo img { display: block; height: auto; }

.es-hd__logo-text {
  font-family: 'Playfair Display', Georgia, serif;
  font-size: 1.4rem;
  font-weight: 600;
  color: #071321;
  text-decoration: none;
  letter-spacing: .02em;
}

/* Search bar */
.es-hd__search { flex: 1; }

.es-hd__search-form {
  display: flex;
  align-items: center;
  background: #fdf8f0;
  border: 1.5px solid #e8e0d0;
  border-radius: 40px;
  padding: 0 6px 0 20px;
  transition: border-color .2s;
}

.es-hd__search-form:focus-within {
  border-color: #C9A646;
}

.es-hd__search-input {
  flex: 1;
  border: none;
  background: transparent;
  padding: 10px 0;
  font-size: .9rem;
  color: #1a1008;
  outline: none;
  min-width: 0;
}

.es-hd__search-input::placeholder { color: #b0a898; }

.es-hd__search-btn {
  width: 36px; height: 36px;
  border: none;
  background: #071321;
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  cursor: pointer;
  flex-shrink: 0;
  transition: background .2s;
}

.es-hd__search-btn:hover { background: #C9A646; }

.es-hd__search-btn svg { stroke: #fff; }

/* Icons */
.es-hd__icons {
  display: flex;
  align-items: center;
  gap: 4px;
  flex-shrink: 0;
}

.es-hd__icon-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2px;
  padding: 6px 10px;
  color: #071321;
  text-decoration: none;
  border-radius: 4px;
  transition: color .2s, background .2s;
  cursor: pointer;
  background: none;
  border: none;
}

.es-hd__icon-btn:hover { color: #C9A646; }

.es-hd__icon-btn svg { stroke: currentColor; flex-shrink: 0; }

.es-hd__icon-label {
  font-size: .65rem;
  font-weight: 600;
  letter-spacing: .06em;
  text-transform: uppercase;
  line-height: 1;
  color: inherit;
}

/* Cart count badge */
.es-hd__cart-wrap { position: relative; display: inline-flex; }

.es-hd__cart-count {
  position: absolute;
  top: -6px; right: -8px;
  min-width: 16px; height: 16px;
  background: #C9A646;
  color: #071321;
  font-size: 9px;
  font-weight: 700;
  border-radius: 8px;
  display: flex; align-items: center; justify-content: center;
  padding: 0 3px;
  line-height: 1;
}

/* Hide legacy number-cart styling conflicts */
#header .es-hd__cart-count.number-cart { display: flex !important; }

/* ── Row 2: Navigation ── */
.es-hd__nav {
  background: #fff;
  padding: 0;
  border-top: none;
}

.es-hd__menu-wrap {
  display: flex;
  justify-content: center;
}

/* Strip ALL borders/lines from every nav element */
.es-hd__menu-wrap *,
.es-hd__menu-wrap ul,
.es-hd__menu-wrap li,
.es-hd__menu-wrap a {
  border: none !important;
  border-top: none !important;
  border-bottom: none !important;
  border-left: none !important;
  border-right: none !important;
  outline: none !important;
  box-shadow: none !important;
  background-image: none !important;
}

/* Centre the nav links */
.es-hd__menu-wrap > ul,
.es-hd__menu-wrap .navbar-nav {
  display: flex !important;
  justify-content: center !important;
  align-items: center !important;
  flex-wrap: wrap;
  gap: 0;
  margin: 0 !important;
  padding: 0 !important;
  list-style: none !important;
  background: none !important;
}

.es-hd__menu-wrap .nav-item > .nav-link,
.es-hd__menu-wrap ul > li > a {
  font-size: .82rem !important;
  font-weight: 700 !important;
  letter-spacing: .08em !important;
  text-transform: uppercase !important;
  color: #071321 !important;
  padding: 13px 20px !important;
  text-decoration: none !important;
  display: block !important;
  transition: color .2s !important;
  white-space: nowrap !important;
  background: none !important;
  line-height: 1.4 !important;
}

.es-hd__menu-wrap .nav-item > .nav-link:hover,
.es-hd__menu-wrap ul > li > a:hover,
.es-hd__menu-wrap .nav-item.active > .nav-link {
  color: #C9A646 !important;
  background: none !important;
}

/* Dropdown arrow colour */
.es-hd__menu-wrap .nav-link .caret,
.es-hd__menu-wrap .nav-link i { color: inherit !important; }

/* Sticky shadow state */
.es-hd.menu_scroll_v2 .es-hd__top,
.es-hd.menu_scroll_v2 .es-hd__nav {
  background: #fff;
}
</style>
