<style>
/* ============================================================
   EternaScents Header v2 — redesigned
   ============================================================ */
@import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600&display=swap');

/* ── Outer header shell ── */
.es-hd {
  background: #fff;
  border-bottom: 1px solid #e8e0d0;
  position: relative;
  z-index: 999;
}

.es-hd.menu_scroll_v2 {
  position: fixed;
  top: 0; left: 0; right: 0;
  box-shadow: 0 2px 20px rgba(7,19,33,.10);
  animation: es-hd-drop .25s ease;
}

@keyframes es-hd-drop {
  from { transform: translateY(-100%); opacity: 0; }
  to   { transform: translateY(0);     opacity: 1; }
}

/* ── Row 1 ── */
.es-hd__top {
  padding: 12px 0;
  border-bottom: 1px solid #f0ebe0;
}

.es-hd__top-inner {
  display: flex;
  align-items: center;
  gap: 24px;
}

/* Logo */
.es-hd__logo { flex-shrink: 0; }

.es-hd__logo-link { display: block; line-height: 1; }

.es-hd__logo img { display: block; height: auto; }

.es-hd__logo-text {
  font-family: 'Playfair Display', Georgia, serif;
  font-size: 1.4rem;
  font-weight: 600;
  color: #071321;
  text-decoration: none;
  letter-spacing: .02em;
}

/* Search bar */
.es-hd__search { flex: 1; }

.es-hd__search-form {
  display: flex;
  align-items: center;
  background: #fdf8f0;
  border: 1.5px solid #e8e0d0;
  border-radius: 40px;
  padding: 0 6px 0 20px;
  transition: border-color .2s;
}

.es-hd__search-form:focus-within {
  border-color: #C9A646;
}

.es-hd__search-input {
  flex: 1;
  border: none;
  background: transparent;
  padding: 10px 0;
  font-size: .9rem;
  color: #1a1008;
  outline: none;
  min-width: 0;
}

.es-hd__search-input::placeholder { color: #b0a898; }

.es-hd__search-btn {
  width: 36px; height: 36px;
  border: none;
  background: #071321;
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  cursor: pointer;
  flex-shrink: 0;
  transition: background .2s;
}

.es-hd__search-btn:hover { background: #C9A646; }

.es-hd__search-btn svg { stroke: #fff; }

/* Icons */
.es-hd__icons {
  display: flex;
  align-items: center;
  gap: 4px;
  flex-shrink: 0;
}

.es-hd__icon-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2px;
  padding: 6px 10px;
  color: #071321;
  text-decoration: none;
  border-radius: 4px;
  transition: color .2s, background .2s;
  cursor: pointer;
  background: none;
  border: none;
}

.es-hd__icon-btn:hover { color: #C9A646; }

.es-hd__icon-btn svg { stroke: currentColor; flex-shrink: 0; }

.es-hd__icon-label {
  font-size: .65rem;
  font-weight: 600;
  letter-spacing: .06em;
  text-transform: uppercase;
  line-height: 1;
  color: inherit;
}

/* Cart count badge */
.es-hd__cart-wrap { position: relative; display: inline-flex; }

.es-hd__cart-count {
  position: absolute;
  top: -6px; right: -8px;
  min-width: 16px; height: 16px;
  background: #C9A646;
  color: #071321;
  font-size: 9px;
  font-weight: 700;
  border-radius: 8px;
  display: flex; align-items: center; justify-content: center;
  padding: 0 3px;
  line-height: 1;
}

/* Hide legacy number-cart styling conflicts */
#header .es-hd__cart-count.number-cart { display: flex !important; }

/* ── Row 2: Navigation ── */
.es-hd__nav {
  background: #fff;
  padding: 0;
}

/* Nav list */
.es-hd__nav-list {
  display: flex;
  align-items: center;
  justify-content: center;
  list-style: none;
  margin: 0;
  padding: 0;
  gap: 0;
}

/* Nav item */
.es-hd__nav-item {
  position: relative;
  margin: 0;
  padding: 0;
}

/* Nav link */
.es-hd__nav-link {
  display: flex;
  align-items: center;
  gap: 4px;
  padding: 13px 18px;
  font-size: .78rem;
  font-weight: 700;
  letter-spacing: .09em;
  text-transform: uppercase;
  color: #071321;
  text-decoration: none;
  white-space: nowrap;
  transition: color .2s;
  line-height: 1;
}

.es-hd__nav-link:hover,
.es-hd__nav-link.active {
  color: #C9A646;
}

/* Caret */
.es-hd__caret {
  opacity: .5;
  transition: transform .2s;
  flex-shrink: 0;
}

.es-hd__nav-item:hover .es-hd__caret {
  transform: rotate(180deg);
  opacity: 1;
}

/* Dropdown sub-menu */
.es-hd__sub {
  display: none;
  position: absolute;
  top: 100%;
  left: 0;
  min-width: 180px;
  background: #fff;
  border: 1px solid #e8e0d0;
  border-radius: 4px;
  box-shadow: 0 8px 24px rgba(7,19,33,.10);
  list-style: none;
  margin: 0;
  padding: 8px 0;
  z-index: 1000;
}

.es-hd__nav-item:hover .es-hd__sub {
  display: block;
}

.es-hd__sub-link {
  display: block;
  padding: 9px 18px;
  font-size: .78rem;
  font-weight: 500;
  letter-spacing: .04em;
  color: #071321;
  text-decoration: none;
  white-space: nowrap;
  transition: color .15s, background .15s;
}

.es-hd__sub-link:hover {
  color: #C9A646;
  background: #fdf8f0;
}

/* Sticky shadow state */
.es-hd.menu_scroll_v2 .es-hd__top,
.es-hd.menu_scroll_v2 .es-hd__nav {
  background: #fff;
}

/* ── Predictive Search Suggestions ── */
.es-hd__search { position: relative; }

.es-hd__suggestions {
  display: none;
  position: absolute;
  top: calc(100% + 6px);
  left: 0; right: 0;
  background: #fff;
  border: 1px solid #e8e0d0;
  border-radius: 10px;
  box-shadow: 0 12px 36px rgba(7,19,33,.12);
  z-index: 9999;
  overflow: hidden;
}

.es-hd__suggestions.is-open { display: block; }

.es-hd__sug-item {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 10px 16px;
  text-decoration: none;
  color: #071321;
  transition: background .15s;
  border-bottom: 1px solid #f5f0e8;
}

.es-hd__sug-item:last-child { border-bottom: none; }

.es-hd__sug-item:hover { background: #fdf8f0; }

.es-hd__sug-img {
  width: 42px; height: 42px;
  object-fit: cover;
  border-radius: 4px;
  flex-shrink: 0;
  background: #f5f0e8;
}

.es-hd__sug-img-placeholder {
  width: 42px; height: 42px;
  border-radius: 4px;
  background: #f5f0e8;
  flex-shrink: 0;
  display: flex; align-items: center; justify-content: center;
}

.es-hd__sug-info { flex: 1; min-width: 0; }

.es-hd__sug-title {
  font-size: .82rem;
  font-weight: 600;
  color: #071321;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  margin-bottom: 2px;
}

.es-hd__sug-price {
  font-size: .75rem;
  color: #C9A646;
  font-weight: 700;
}

.es-hd__sug-all {
  display: block;
  padding: 10px 16px;
  font-size: .75rem;
  font-weight: 700;
  letter-spacing: .06em;
  text-transform: uppercase;
  color: #071321;
  text-align: center;
  text-decoration: none;
  background: #fdf8f0;
  transition: background .15s, color .15s;
}

.es-hd__sug-all:hover { background: #071321; color: #C9A646; }

.es-hd__sug-loading,
.es-hd__sug-empty {
  padding: 14px 16px;
  font-size: .82rem;
  color: #999;
  text-align: center;
}
</style>

<script>
(function() {
  function formatMoney(cents) {
    if (typeof cents === 'string') cents = cents.replace('.', '');
    var value = (parseInt(cents, 10) / 100).toFixed(2);
    return '£' + value;
  }

  function initPredictiveSearch(wrapperId, suggestionsId) {
    var wrapper = document.getElementById(wrapperId);
    if (!wrapper) return;
    var input = wrapper.querySelector('.es-hd__search-input');
    var box   = document.getElementById(suggestionsId);
    if (!input || !box) return;

    var timer = null;
    var lastQ = '';

    function show(html) {
      box.innerHTML = html;
      box.classList.add('is-open');
    }

    function hide() {
      box.classList.remove('is-open');
      box.innerHTML = '';
    }

    input.addEventListener('input', function() {
      var q = this.value.trim();
      if (q === lastQ) return;
      lastQ = q;
      clearTimeout(timer);
      if (q.length < 2) { hide(); return; }
      show('<div class="es-hd__sug-loading">Searching…</div>');
      timer = setTimeout(function() { fetchSuggestions(q); }, 250);
    });

    input.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') hide();
    });

    document.addEventListener('click', function(e) {
      if (!wrapper.contains(e.target)) hide();
    });

    function fetchSuggestions(q) {
      var url = '/search/suggest.json?q=' + encodeURIComponent(q)
        + '&resources[type]=product&resources[limit]=6&resources[options][fields]=title,variants.title';
      fetch(url)
        .then(function(r) { return r.json(); })
        .then(function(data) {
          var products = (data.resources && data.resources.results && data.resources.results.products) || [];
          if (products.length === 0) {
            show('<div class="es-hd__sug-empty">No products found for "' + escHtml(q) + '"</div>');
            return;
          }
          var html = '';
          products.forEach(function(p) {
            var img = p.featured_image
              ? '<img class="es-hd__sug-img" src="' + p.featured_image + '&width=84" alt="' + escHtml(p.title) + '" loading="lazy">'
              : '<div class="es-hd__sug-img-placeholder"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ccc" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9l4-4 4 4 4-5 4 5"/></svg></div>';
            var price = p.price ? formatMoney(p.price) : '';
            html += '<a href="' + p.url + '" class="es-hd__sug-item">'
              + img
              + '<div class="es-hd__sug-info">'
              + '<div class="es-hd__sug-title">' + escHtml(p.title) + '</div>'
              + (price ? '<div class="es-hd__sug-price">' + price + '</div>' : '')
              + '</div></a>';
          });
          html += '<a href="/search?type=product&q=' + encodeURIComponent(q) + '" class="es-hd__sug-all">View all results for "' + escHtml(q) + '" →</a>';
          show(html);
        })
        .catch(function() {
          show('<div class="es-hd__sug-empty">Search unavailable</div>');
        });
    }

    function escHtml(str) {
      return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }
  }

  document.addEventListener('DOMContentLoaded', function() {
    initPredictiveSearch('es-hd-search-home',  'es-hd-suggestions-home');
    initPredictiveSearch('es-hd-search-other', 'es-hd-suggestions-other');
  });
})();
</script>
