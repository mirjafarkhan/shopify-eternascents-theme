{% elsif settings.product_style == "style_6" %}
{%- comment -%}
  product-item-v1.liquid — style_6 (EternaScents luxury card)
  Zaoud-inspired dual-hover product card.

  Features:
  - Dual image hover: primary → secondary (CSS opacity, no JS)
  - No loading.gif placeholder — CSS aspect-ratio background
  - Explicit image dimensions — fixes CLS
  - "Inspired by X" badge from product tag format: inspired:Name
  - Shopify Reviews badge (star rating + count)
  - Quick Add: AJAX for single-variant, link for multi-variant
  - Price range: "From £X" for multi-variant products
  - Wishlist via existing add-wishlist snippet
  - Sold out: badge + 60% opacity on image
{%- endcomment -%}

{%- comment -%} ── Computed flags ─────────────────────────────────── {%- endcomment -%}
{%- assign on_sale   = false -%}
{%- assign sold_out  = false -%}
{%- assign is_new    = false -%}
{%- assign is_hot    = false -%}
{%- assign is_popular = false -%}

{%- if product.compare_at_price > product.price -%}{%- assign on_sale = true -%}{%- endif -%}
{%- unless product.available -%}{%- assign sold_out = true -%}{%- endunless -%}
{%- if product.tags contains 'hot' -%}{%- assign is_hot = true -%}{%- endif -%}
{%- if product.tags contains 'popular' -%}{%- assign is_popular = true -%}{%- endif -%}

{%- capture _new_cutoff -%}{{ settings.product_new_time | default: 30 | times: 86400 }}{%- endcapture -%}
{%- assign _now = 'now' | date: '%s' | plus: 0 -%}
{%- assign _published = product.published_at | date: '%s' | plus: 0 -%}
{%- assign _cutoff = _now | minus: _new_cutoff -%}
{%- if _published > _cutoff -%}{%- assign is_new = true -%}{%- endif -%}

{%- comment -%} ── "Inspired by" tag extraction ─────────────────── {%- endcomment -%}
{%- assign inspired_by = '' -%}
{%- for tag in product.tags -%}
  {%- if tag contains 'inspired:' -%}
    {%- assign inspired_by = tag | remove: 'inspired:' | strip -%}
  {%- elsif tag contains 'inspired_by:' -%}
    {%- assign inspired_by = tag | remove: 'inspired_by:' | strip -%}
  {%- endif -%}
{%- endfor -%}

{%- comment -%} ── Second image for hover ──────────────────────────
  product.images[1] is the second uploaded image — the standard
  convention for lifestyle/notes photography.
  Only renders the hover layer if a second image exists.
{%- endcomment -%}
{%- assign hover_img = product.images[1] -%}

<div class="es-product-card product-item-v6 mb-30">

  {%- comment -%} ── IMAGE ZONE ──────────────────────────────────── {%- endcomment -%}
  <div class="es-product-card__img-wrap">

    <a href="{{ product.url | within: collection }}" class="es-product-card__img-link" tabindex="0" aria-label="{{ product.title | escape }}">

      {%- comment -%} Primary image {%- endcomment -%}
      <div class="es-product-card__img-primary{% if sold_out %} es-product-card__img-primary--soldout{% endif %}">
        {%- if product.featured_image -%}
          <img
            src="{{ product.featured_image | image_url: width: 600, height: 600, crop: 'center' }}"
            alt="{{ product.featured_image.alt | default: product.title | escape }}"
            width="600"
            height="600"
            loading="lazy"
            class="es-product-card__img">
        {%- else -%}
          {{ 'product-1' | placeholder_svg_tag: 'es-product-card__img es-product-card__img--placeholder' }}
        {%- endif -%}
      </div>

      {%- comment -%} Hover image — only if second image exists {%- endcomment -%}
      {%- if hover_img -%}
        <div class="es-product-card__img-hover">
          <img
            src="{{ hover_img | image_url: width: 600, height: 600, crop: 'center' }}"
            alt="{{ hover_img.alt | default: product.title | escape }}"
            width="600"
            height="600"
            loading="lazy"
            class="es-product-card__img">
        </div>
      {%- endif -%}

    </a>

    {%- comment -%} ── LABELS (top-left) ─────────────────────────── {%- endcomment -%}
    <div class="es-product-card__labels">
      {%- if sold_out -%}
        <span class="es-product-card__label es-product-card__label--soldout">Sold Out</span>
      {%- elsif on_sale and settings.enable_sale_label -%}
        {%- assign sale_pct = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price -%}
        <span class="es-product-card__label es-product-card__label--sale"
          style="background:{{ settings.sale_label_color }};color:{{ settings.sale_label_text_color }}">
          -{{ sale_pct }}%
        </span>
      {%- elsif is_new -%}
        <span class="es-product-card__label es-product-card__label--new">New</span>
      {%- elsif is_hot -%}
        <span class="es-product-card__label es-product-card__label--hot">Hot</span>
      {%- elsif is_popular -%}
        <span class="es-product-card__label es-product-card__label--popular">Popular</span>
      {%- endif -%}
    </div>

    {%- comment -%} ── WISHLIST (top-right) ──────────────────────── {%- endcomment -%}
    <div class="es-product-card__wishlist">
      {%- render 'add-wishlist' -%}
