<style>
@import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&display=swap');
/* ─── Product Card (style_6) ────────────────────────────────────────── */
.es-product-card {
  position: relative;
  display: flex;
  flex-direction: column;
}

/* ─── Image zone ────────────────────────────────────────────────────── */
.es-product-card__img-wrap {
  position: relative;
  overflow: hidden;
  background: #fdf8f0; /* warm ivory — exact match to luxury PDP palette */
  /* Force square aspect ratio without loading.gif */
  aspect-ratio: 1 / 1;
}

.es-product-card__img-link {
  display: block;
  width: 100%;
  height: 100%;
}

/* Primary image */
.es-product-card__img-primary {
  position: absolute;
  inset: 0;
  z-index: 1;
  transition: opacity 0.4s ease;
}

.es-product-card__img-primary--soldout {
  opacity: 0.55;
}

/* Hover image — sits on top, starts invisible */
.es-product-card__img-hover {
  position: absolute;
  inset: 0;
  z-index: 2;
  opacity: 0;
  transition: opacity 0.4s ease;
}

/* Trigger hover: fade in second image, slightly scale primary */
.es-product-card__img-wrap:hover .es-product-card__img-hover {
  opacity: 1;
}

.es-product-card__img-wrap:hover .es-product-card__img-primary {
  transform: scale(1.03);
}

.es-product-card__img-primary {
  transition: opacity 0.4s ease, transform 0.5s ease;
}

.es-product-card__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
  display: block;
}

.es-product-card__img--placeholder {
  width: 100%;
  height: 100%;
}

/* ─── Labels ────────────────────────────────────────────────────────── */
.es-product-card__labels {
  position: absolute;
  top: 10px;
  left: 10px;
  z-index: 4;
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.es-product-card__label {
  display: inline-block;
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  padding: 3px 8px;
  line-height: 1.4;
}

.es-product-card__label--soldout {
  background: #071321;
  color: #ffffff;
}

.es-product-card__label--new {
  background: #C9A646;
  color: #071321;
}

.es-product-card__label--hot {
  background: #e12c43;
  color: #ffffff;
}

.es-product-card__label--popular {
  background: #2d6a4f;
  color: #ffffff;
}

/* ─── Wishlist ──────────────────────────────────────────────────────── */
.es-product-card__wishlist {
  position: absolute;
  top: 10px;
  right: 10px;
  z-index: 4;
  opacity: 0;
  transform: translateX(4px);
  transition: opacity 0.25s, transform 0.25s;
}

.es-product-card__img-wrap:hover .es-product-card__wishlist {
  opacity: 1;
  transform: translateX(0);
}

/* ─── Quick Add ─────────────────────────────────────────────────────── */
.es-product-card__quick-add {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 4;
  transform: translateY(100%);
  transition: transform 0.28s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}

.es-product-card__img-wrap:hover .es-product-card__quick-add {
  transform: translateY(0);
}

.es-product-card__quick-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  width: 100%;
  padding: 12px 16px;
  background: #071321;
  color: #C9A646;
  border: none;
  cursor: pointer;
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  text-decoration: none;
  transition: background 0.2s, color 0.2s;
}

.es-product-card__quick-btn:hover {
  background: #C9A646;
  color: #071321;
}

.es-product-card__quick-btn svg {
  width: 14px;
  height: 14px;
  flex-shrink: 0;
}

.es-product-card__atc-form {
  width: 100%;
  margin: 0;
}

/* ─── Card body ─────────────────────────────────────────────────────── */
.es-product-card__body {
  padding: 12px 4px 0;
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4px;
}

/* ─── Inspired by ───────────────────────────────────────────────────── */
.es-product-card__inspired {
  font-size: 10px;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: #C9A646;
  margin: 0;
  line-height: 1.4;
}

.es-product-card__inspired-label {
  color: #999;
  margin-right: 3px;
}

/* ─── Reviews ───────────────────────────────────────────────────────── */
.es-product-card__rating {
  min-height: 16px; /* reserve space so layout doesn't shift when SPR loads */
}

.es-product-card__rating .shopify-product-reviews-badge {
  display: block;
}

/* ─── Title — Playfair Display serif, matching luxury PDP ───────────── */
.es-product-card__title {
  font-family: 'Playfair Display', Georgia, serif;
  font-size: 14px;
  font-weight: 600;
  letter-spacing: 0;
  text-transform: none;
  margin: 0;
  line-height: 1.3;
}

.es-product-card__title a {
  color: #071321;
  text-decoration: none;
  transition: color 0.2s;
}

.es-product-card__title a:hover {
  color: #C9A646;
}

/* ─── Vendor ────────────────────────────────────────────────────────── */
.es-product-card__vendor {
  font-size: 11px;
  color: #999;
  margin: 0;
  letter-spacing: 0.04em;
}

/* ─── Price ─────────────────────────────────────────────────────────── */
.es-product-card__price {
  font-size: 13px;
  margin: 2px 0 0;
  display: flex;
  align-items: baseline;
  gap: 6px;
  flex-wrap: wrap;
}

.es-product-card__price-compare {
  color: #bbb;
  font-size: 11px;
  text-decoration: line-through;
}

.es-product-card__price-current {
  color: #071321;
  font-weight: 700;
  text-decoration: underline;
  text-decoration-color: #C9A646;
  text-underline-offset: 3px;
  text-decoration-thickness: 1.5px;
}

.es-product-card__price-current--sale {
  color: #C9A646;
}

/* ─── Mobile: always show quick add (no hover on touch) ─────────────── */
@media (hover: none) and (pointer: coarse) {
  .es-product-card__quick-add {
    transform: translateY(0);
  }
  .es-product-card__wishlist {
    opacity: 1;
    transform: translateX(0);
  }
}

/* ─── Reduced motion ────────────────────────────────────────────────── */
@media (prefers-reduced-motion: reduce) {
  .es-product-card__img-hover,
  .es-product-card__img-primary,
  .es-product-card__quick-add,
  .es-product-card__wishlist { transition: none; }
}
</style>

{% elsif settings.product_style == "style_7"  %}
<div class="product-item-v7">

  {% assign product_label_new = false %}
  {% capture _time %}{{ settings.product_new_time | times: 86400 }}{% endcapture %} 
  {% assign time = _time | plus: 0 %}
  {% assign now = 'now' | date: '%s' | plus: 0 %}

  {% capture _value %}{{ product.published_at | date: "%s" | plus : time }}{% endcapture %} 
  {% assign value = _value | plus: 0 %}

  {% if now < value %}
  {% assign product_label_new = true %}
  {% endif %}


  {% assign label_popular = false %}
  {% if product.tags contains "popular" %}
  {% assign label_popular = true %}
  {% endif %} 

  {% assign label_hot = false %}
  {% if product.tags contains "hot" %}
  {% assign label_hot = true %}
  {% endif %}

  {% assign on_sale = false %}
  {% if product.compare_at_price > product.price %}
  {% assign on_sale = true %}
  {% endif %}

  {% assign sold_out = true %}
  {% if product.available %}
  {% assign sold_out = false %}
  {% endif %}
  <div class="product mb-30 engoj_grid_parent relative">
    <div class="img-product relative">
      <a href="{{ product.url | within: collection }}" class="engoj_find_img">
        <img loading="lazy" width="" height="" style="width: 100%" data-src="{{ product.featured_image.src | image_url }}" src="{{ 'loading.gif' | asset_url }}" class="lazyload img-responsive" alt="{{ product.featured_image.alt | escape }}">
        {% for image in product.images %}
        {% if forloop.last %}
        <img loading="lazy" width="" height="" style="width: 100%" data-src="{{ image.src | image_url }}" src="{{ 'loading.gif' | asset_url }}" class="lazyload img-responsive absolute img-product-hover" alt="{{ product.featured_image.alt | escape }}">
        {% endif %}
        {% endfor %}
      </a>  
      <!--     label product -->
      {% assign product_label_new = false %}
      {% capture _time %}{{ settings.product_new_time | times: 86400 }}{% endcapture %} 
      {% assign time = _time | plus: 0 %}
      {% assign now = 'now' | date: '%s' | plus: 0 %}

      {% capture _value %}{{ product.published_at | date: "%s" | plus : time }}{% endcapture %} 
      {% assign value = _value | plus: 0 %}

      {% if now < value %}
      {% assign product_label_new = true %}
      {% endif %}


      {% assign label_popular = false %}
      {% if product.tags contains "popular" %}
      {% assign label_popular = true %}
      {% endif %} 

      {% assign label_hot = false %}
      {% if product.tags contains "hot" %}
      {% assign label_hot = true %}
      {% endif %}

      {% assign on_sale = false %}
      {% if product.compare_at_price > product.price %}
      {% assign on_sale = true %}
      {% endif %}

      {% assign sold_out = true %}
      {% if product.available %}
      {% assign sold_out = false %}
      {% endif %}	
      {% if on_sale %}
      {% if settings.show_sale_label %}
      {% assign sale= product.price | minus : product.compare_at_price | times : 100 | divided_by: product.compare_at_price %}
      <figure style= "background : {{ settings.sale_label_color }}; color: {{ settings.sale_label_text_color }}" class="absolute uppercase label-sale text-center">
        <span class="sale-percent">{{sale}}%</span>
      </figure>
      {% endif %}
      {% endif %}

      <!--     END LABEL -->


      <!--     ICON PRODUCT -->

      {% assign sold_out = true %}
      {% if product.available %}
      {% assign sold_out = false %}
      {% endif %}
      <ul class="product-icon-action list-unstyled mb-0 text-center">     

        <li class="add-to-cart mr-0">
          {% if sold_out %}
          <a href="{{ product.url | within: collection }}" class="inline-block icon-addcart  box-shadow" data-toggle="tooltip" data-placement="top" data-original-title="{{ settings.pia_sold_name }}">
            {% if settings.pia_sold_svg != blank %}
            <i class="fsz-unset">{{ settings.pia_sold_svg }}</i>
            {% else %}
            <i class="{{ settings.pia_sold }}"></i>
            {% endif %}
          </a>
          {% else %}
          {% if product.variants.size > 1 %}
          <a href="{{ product.url | within: collection }}" class="inline-block icon-addcart  box-shadow" data-toggle="tooltip" data-placement="top" data-original-title="{{ settings.pia_selectoption_name }}">
            {% if settings.pia_selectoption_svg != blank %}
            <i class="fsz-unset">{{ settings.pia_selectoption_svg }}</i>
            {% else %}
            <i class="{{ settings.pia_selectoption }}"></i>
            {% endif %}
          </a>
          {% else %}
          <form method="post" action="/cart/add" enctype="multipart/form-data" class="inline-block icon-addcart  box-shadow"  data-toggle="tooltip" data-placement="top" data-original-title="{{ settings.pia_addcart_name }}">
            <input type="hidden" name="id" value="{{ product.variants.first.id }}" />
            <button type="submit" name="add" class="enj-add-to-cart-btn ">
              {% if settings.pia_addcart_svg != blank %}
              <i class="fsz-unset">{{ settings.pia_addcart_svg }}</i>
              {% else %}
              <i class="{{ settings.pia_addcart }}"></i>
              {% endif %}
            </button>
          </form>
          {% endif %}
          {% endif %}
        </li>  
        <li class="quick-view mr-0">
          <a href="javascript:void(0)" class="engoj_btn_quickview icon-quickview inline-block box-shadow" data-id="{{ product.handle }}" data-toggle="tooltip" data-placement="top" data-original-title="{{ settings.pia_quickview_name }}">
            {% if settings.pia_quickview_svg != blank %}
            <i class="fsz-unset">{{ settings.pia_quickview_svg }}</i>
            {% else %}
            <i class="{{ settings.pia_quickview }}"></i>
            {% endif %}
          </a>
        </li>
        <li class="add-wishlist mr-0">
          {% include 'add-wishlist' %} 
        </li>


      </ul>
      <!--     END ICON -->
      
      {% if product.metafields.engo_countdown_prod.countdown_datetime != blank %}
      <div class="countdown-timer text-center">
        <ul data-countdown="countdown-v1" data-date="{{ product.metafields.engo_countdown_prod.countdown_datetime }}">

        </ul>
      </div> 
      {% endif %}

    </div>

    <h4 class="des-font capital title-product mb-0">
      <a href="{{ product.url | within: collection }}">{{ product.title | strip_html | truncatewords : 4 }}</a>      
    </h4>
    <!--     PRICE -->
    {% assign on_sale = false %}
    {% if product.compare_at_price > product.price %}
    {% assign on_sale = true %}
    {% endif %}

    <p class="price-product mb-0">
      {% if on_sale %}<s class="price-old">{{ product.compare_at_price | money }}</s>{% endif %}
      <span class="price">{{ product.price | money }}</span>
    </p>
    <!-- END PRODUCT     -->

    <!-- VARIANT PRODUCT -->

    <nav class="engoj_select_color variant-product">
      {% for option in product.options %}
      {% if option == 'Color' or option == 'Colour' %}
      {% assign index = forloop.index0 %}
      {% assign colorlist = '' %}
      {% assign color = '' %}
      {% for variant in product.variants %}
      {% capture color %}{{ variant.options[index] }}{% endcapture %}
      {% unless colorlist contains color %}

      {% assign text = color | handleize %}
      <span class="">
        <a class="circle mr-0" href="javascript:void(0)" {% if variant.image != null %}data-engojvariant-img="{{ variant.image.src | product_img_url: 'grande' }}"{% endif %} style="{% if text == 'white' %}border: 1px solid #bcbcbc; {% endif %}background-color: {{ color | split: ' ' | last | handle }};"></a>
      </span>

      {% capture tempList %}
      {{ colorlist | append: color | append: ' ' }}
      {% endcapture %}

      {% assign colorlist = tempList %}
      {% endunless %}

      {% endfor %}
      {% endif %}
      {% endfor %}
    </nav>


    <!-- END VARIANT     -->

    <!--     THUMBNAIL PRODUCT -->

    {% if settings.show_thumbnai_pd %}
    {% if product.variants.size > 1 %}

    <div class="variant-image-group engoj_select_color space_top_20">
      {% for option in product.options %}
      {% if option == 'Color' %}
      {% assign index = forloop.index0 %}
      {% assign colorlist = '' %}
      {% assign color = '' %}
      {% for variant in product.variants %}
      {% capture color %}{{ variant.options[index] }}{% endcapture %}
      {% unless colorlist contains color %}

      {% assign text = color | handleize %}
      <span class="border">
        <a  class="circle-thumb" href="javascript:void(0)" {% if variant.image != null %}data-engojvariant-img="{{ variant.image.src | product_img_url: 'grande' }}"{% endif %} style="{% if text == 'white' %}border: 1px solid #bcbcbc; {% endif %}background-image: url({{ variant.image.src | product_img_url: 'grande' }});background-size:cover;"></a>
      </span>

      {% capture tempList %}
      {{ colorlist | append: color | append: ' ' }}
      {% endcapture %}

      {% assign colorlist = tempList %}
      {% endunless %}

      {% endfor %}
      {% endif %}
      {% endfor %}
    </div>
    {%endif%}
    {% endif %}

    <!-- END THUMBNAIL     -->

  </div>

</div>  
