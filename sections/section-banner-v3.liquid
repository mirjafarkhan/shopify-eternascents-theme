<div data-section-id="{{ section.id }}" data-section-type="section-banner-v3" style="{% if section.settings.margin_top != blank %}margin-top: {{section.settings.margin_top}}px;{%endif%} {% if section.settings.margin_bottom != blank %}margin-bottom: {{section.settings.margin_bottom}}px;{% endif %}">
  <div class="section-banner-v3 mt-all">
    <div class="lazyload">
      <div class="container container-v1">
        <div class="row">        
          <div class="col-lg-6 col-md-6 col-12 col-sm-12">
            <div class="box-info">
              <div class="box-img-one">
                {% if section.settings.img_banner1 != blank %}
                <a href="{{section.settings.url_banner1}}">
                  <img data-src="{{section.settings.img_banner1 | img_url:'master'}}" class="lazyload img-fluid w-100" alt="_img"></a>
                {% else %}
                <a href="{{section.settings.url_banner1}}">
                  <img data-src="//via.placeholder.com/700x388" class="lazyload img-fluid w-100" alt="_img"></a>
                {% endif %}
              </div>
              <div class="content-banner">
                {% if section.settings.title_1 != blank %}
                <h3 class="title mb-0" style="color: {{section.settings.color_title1}}">
                  {{section.settings.title_1}}
                </h3>
                {% endif %}
                <div class="list-inline info-bottom"> 
                  {% if section.settings.button_1 != blank %}
                  <a href="{{section.settings.url_button1}}" style="color: {{section.settings.color_button1}}" class="button-shop one">
                    {{section.settings.button_1}}
                  </a>
                  {% endif %}
                </div>
              </div>
            </div>
          </div>
          <div class="col-lg-6 col-md-6 col-12 col-sm-12">
            <div class="box-info">
              <div class="box-img-one">
                {% if section.settings.img_banner2 != blank %}
                <a href="{{section.settings.url_banner2}}">
                  <img data-src="{{section.settings.img_banner2 | img_url:'master'}}" class="lazyload img-fluid w-100" alt="_img"></a>
                {% else %}
                <a href="{{section.settings.url_banner2}}">
                  <img data-src="//via.placeholder.com/700x388" class="lazyload img-fluid w-100" alt="_img"></a>
                {% endif %}
              </div>
              <div class="content-banner">
                {% if section.settings.title_2 != blank %}
                <h3 class="title mb-0" style="color: {{section.settings.color_title2}}">
                  {{section.settings.title_2}}
                </h3>
                {% endif %}
                <div class="list-inline info-bottom"> 
                  {% if section.settings.button_2 != blank %}
                  <a href="{{section.settings.url_button2}}" style="color: {{section.settings.color_button2}}" class="button-shop two">
                    {{section.settings.button_2}}
                  </a>
                  {% endif %}
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
.section-banner-v3 .box-info .content-banner .info-bottom a.one:hover {
  color: {{section.settings.color_button_hover1}} !important;
}
.section-banner-v3 .box-info .content-banner .info-bottom a.one:before {
  background: {{section.settings.color_button_hover1}};
}
.section-banner-v3 .box-info .content-banner .info-bottom a.one:after {
  background: {{section.settings.color_button1}};
}
.section-banner-v3 .box-info .content-banner .info-bottom a.two:hover {
  color: {{section.settings.color_button_hover2}} !important;
}
.section-banner-v3 .box-info .content-banner .info-bottom a.two:before {
  background: {{section.settings.color_button_hover2}};
}
.section-banner-v3 .box-info .content-banner .info-bottom a.two:after {
  background: {{section.settings.color_button2}};
}
</style>
