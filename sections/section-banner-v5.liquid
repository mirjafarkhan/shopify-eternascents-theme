<div data-section-id="{{ section.id }}" data-section-type="section-banner-v5" style="{% if section.settings.margin_top != blank %}margin-top: {{section.settings.margin_top}}px;{%endif%} {% if section.settings.margin_bottom != blank %}margin-bottom: {{section.settings.margin_bottom}}px;{% endif %}">
  <div class="section-banner-v5 mt-all">
    <div class="container container-v2">
      <div class="row">        
        <div class="col-lg-6 col-md-6 col-12 col-sm-12">
          <div class="banner-box">
            <div class="box-img">
              <a href="{{section.settings.url_button1}}">
                {% if section.settings.img_banner1 != blank %}
                <img src="{{section.settings.img_banner1 | img_url:'master'}}" class="img-fluid">
                {% else %}
                <img src="//via.placeholder.com/687x405" class="img-fluid" alt="">
                {% endif %}
              </a>
            </div>            
            <div class="banner-info"> 
              
              {% if section.settings.sub-title-1 != blank %}
              <p class="sub-title" style="color : {{section.settings.color_subtitle1}}">
                {{section.settings.sub-title-1}}
              </p>
              {% endif %}
              
              {% if section.settings.title_1 != blank %}
              <h3 class="title" style="color : {{section.settings.color_title1}}">
                {{section.settings.title_1}}
              </h3>
              {% endif %}

              {% if section.settings.button_1 != blank %}
              <a href="{{section.settings.url_button1}}" class="button-main1">
                {{section.settings.button_1}}
              </a>
              {% endif %}
              
            </div>            
          </div>
        </div>
        
        
        <div class="col-lg-6 col-md-6 col-12 col-sm-12 mt-4 mt-sm-0">
          <div class="banner-box">
            <div class="box-img">
              <a href="{{section.settings.url_button2}}">
                {% if section.settings.img_banner2 != blank %}
                <img src="{{section.settings.img_banner2 | img_url:'master'}}" class="img-fluid">
                {% else %}
                <img src="//via.placeholder.com/687x405" class="img-fluid" alt="">
                {% endif %}
              </a>
            </div>            
            <div class="banner-info">
              {% if section.settings.sub-title-2 != blank %}
              <p class="sub-title" style="color : {{section.settings.color_subtitle2}}">
                {{section.settings.sub-title-2}}
              </p>
              {% endif %}
              
              {% if section.settings.title_2 != blank %}
              <h3 class="title" style="color : {{section.settings.color_title2}}">
                {{section.settings.title_2}}
              </h3>
              {% endif %}
              

              {% if section.settings.button_2 != blank %}
              <a href="{{section.settings.url_button2}}" class="button-main1">
                {{section.settings.button_2}}
              </a>
              {% endif %}
              
            </div>            
          </div>
        </div>
   
        
      </div>
    </div>
  </div>
</div>

<style>
  .section-banner-v5 .banner-box .banner-info .button-main1 {
    background : {{block.settings.bg_color_block_button}};
    color : {{block.settings.color_block_button}};
  }
  .section-banner-v5 .banner-box .banner-info .button-main1:hover {
    background : {{block.settings.bg_color_hover_button}};
    color : {{block.settings.color_hover_text}};
  }
</style>
