{%- comment -%}
  sections/es-testimonials.liquid
  Customer reviews / testimonials — luxury carousel, pure CSS, no JS.
  Falls back to a clean grid on mobile.
  Uses CSS scroll-snap for swipeable mobile experience.
{%- endcomment -%}

{%- assign bg   = section.settings.bg_color   | default: '#071321' -%}
{%- assign gold = section.settings.gold_color  | default: '#C9A646' -%}
{%- assign text = section.settings.text_color  | default: '#ffffff' -%}

<section
  data-section-id="{{ section.id }}"
  data-section-type="es-testimonials"
  class="es-testimonials"
  style="background: {{ bg }};"
  aria-label="Customer reviews">

  <div class="es-testimonials__inner">

    <header class="es-testimonials__header es-reveal">
      {%- if section.settings.eyebrow != blank -%}
        <p class="es-testimonials__eyebrow" style="color: {{ gold }};">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="es-testimonials__heading" style="color: {{ text }};">{{ section.settings.heading }}</h2>
      {%- endif -%}
      <div class="es-testimonials__stars" aria-label="5 star rated" role="img">
        {%- for i in (1..5) -%}
          <svg viewBox="0 0 20 20" fill="{{ gold }}" width="18" height="18" aria-hidden="true">
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
          </svg>
        {%- endfor -%}
      </div>
    </header>

    {%- if section.blocks.size > 0 -%}
      <div class="es-testimonials__track" role="list">
        {%- for block in section.blocks -%}
          {%- if block.type == 'review' -%}
            <article
              class="es-testimonials__card"
              role="listitem"
              aria-label="Review by {{ block.settings.name | escape }}"
              {{ block.shopify_attributes }}>

              <div class="es-testimonials__quote-icon" aria-hidden="true" style="color: {{ gold }};">
                <svg viewBox="0 0 32 24" fill="currentColor" width="32" height="24">
                  <path d="M0 24V14.4C0 6.4 5.4.8 16.2 0L18 3.6C13.4 4.8 10.4 7.8 10 12H14.4V24H0zm17.6 0V14.4c0-8 5.4-13.6 16.2-14.4L35.6 3.6C31 4.8 28 7.8 27.6 12H32V24H17.6z"/>
                </svg>
              </div>

              {%- if block.settings.review_text != blank -%}
                <blockquote class="es-testimonials__text" style="color: rgba(255,255,255,0.85);">
                  {{ block.settings.review_text }}
                </blockquote>
              {%- endif -%}

              {%- assign star_count = block.settings.stars | default: 5 -%}
              <div class="es-testimonials__card-stars" aria-label="{{ star_count }} stars">
                {%- for i in (1..5) -%}
                  {%- if forloop.index <= star_count -%}
                    <svg viewBox="0 0 20 20" fill="{{ gold }}" width="14" height="14" aria-hidden="true"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                  {%- else -%}
                    <svg viewBox="0 0 20 20" fill="rgba(201,166,70,0.25)" width="14" height="14" aria-hidden="true"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                  {%- endif -%}
                {%- endfor -%}
              </div>

              <footer class="es-testimonials__author">
                {%- if block.settings.avatar != blank -%}
                  <img
                    src="{{ block.settings.avatar | image_url: width: 80 }}"
                    alt="{{ block.settings.name | escape }}"
                    width="44"
                    height="44"
                    loading="lazy"
                    class="es-testimonials__avatar">
                {%- else -%}
                  <div class="es-testimonials__avatar-placeholder" style="background: linear-gradient(135deg, {{ gold }}44, {{ gold }}22); color: {{ gold }};" aria-hidden="true">
                    {{ block.settings.name | slice: 0 | upcase }}
                  </div>
                {%- endif -%}
                <div>
                  <p class="es-testimonials__name" style="color: {{ text }};">{{ block.settings.name }}</p>
                  {%- if block.settings.location != blank -%}
                    <p class="es-testimonials__location" style="color: rgba(255,255,255,0.45);">{{ block.settings.location }}</p>
                  {%- endif -%}
                </div>
              </footer>

            </article>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- if section.settings.cta_label != blank -%}
      <div class="es-testimonials__cta-wrap">
        <a
          href="{{ section.settings.cta_url | default: '/pages/reviews' }}"
          class="es-testimonials__cta"
          style="border-color: {{ gold }}; color: {{ gold }};">
          {{ section.settings.cta_label }}
        </a>
      </div>
    {%- endif -%}

  </div>
</section>

<style>
.es-testimonials {
  padding: 88px 0;
}

.es-testimonials__inner {
  max-width: 1240px;
  margin: 0 auto;
  padding: 0 32px;
}

.es-testimonials__header {
  text-align: center;
  margin-bottom: 56px;
}

.es-testimonials__eyebrow {
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  margin: 0 0 12px;
}

.es-testimonials__heading {
  font-family: 'Playfair Display', Georgia, serif;
  font-size: clamp(26px, 3vw, 42px);
  font-weight: 700;
  margin: 0 0 20px;
}

.es-testimonials__stars {
  display: flex;
  justify-content: center;
  gap: 4px;
}

/* ─── Track / Grid ───────────────────────────────────────────────────── */
.es-testimonials__track {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24px;
}

/* ─── Card ───────────────────────────────────────────────────────────── */
.es-testimonials__card {
  background: rgba(255,255,255,0.04);
  border: 1px solid rgba(201,166,70,0.15);
  padding: 36px 32px 28px;
  display: flex;
  flex-direction: column;
  gap: 16px;
  position: relative;
  transition: border-color 0.3s, background 0.3s, transform 0.3s;
}

.es-testimonials__card:hover {
  border-color: rgba(201,166,70,0.5);
  background: rgba(255,255,255,0.07);
  transform: translateY(-4px);
}

.es-testimonials__quote-icon {
  flex-shrink: 0;
}

.es-testimonials__text {
  font-size: 15px;
  line-height: 1.8;
  font-style: italic;
  margin: 0;
  flex: 1;
}

.es-testimonials__card-stars {
  display: flex;
  gap: 2px;
}

.es-testimonials__author {
  display: flex;
  align-items: center;
  gap: 12px;
  padding-top: 16px;
  border-top: 1px solid rgba(201,166,70,0.12);
}

.es-testimonials__avatar {
  width: 44px;
  height: 44px;
  border-radius: 50%;
  object-fit: cover;
  flex-shrink: 0;
}

.es-testimonials__avatar-placeholder {
  width: 44px;
  height: 44px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16px;
  font-weight: 700;
  flex-shrink: 0;
  border: 1px solid rgba(201,166,70,0.3);
}

.es-testimonials__name {
  font-size: 13px;
  font-weight: 700;
  margin: 0;
  letter-spacing: 0.04em;
}

.es-testimonials__location {
  font-size: 11px;
  margin: 2px 0 0;
  letter-spacing: 0.04em;
}

/* ─── CTA ────────────────────────────────────────────────────────────── */
.es-testimonials__cta-wrap {
  text-align: center;
  margin-top: 48px;
}

.es-testimonials__cta {
  display: inline-block;
  padding: 13px 40px;
  border: 1.5px solid;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  text-decoration: none;
  transition: background 0.25s, color 0.25s;
}

.es-testimonials__cta:hover {
  background: #C9A646;
  color: #071321 !important;
}

/* ─── Mobile ─────────────────────────────────────────────────────────── */
@media (max-width: 900px) {
  .es-testimonials { padding: 56px 0; }
  .es-testimonials__inner { padding: 0 16px; }
  .es-testimonials__track {
    grid-template-columns: 1fr;
    gap: 16px;
  }
}

@media (max-width: 640px) {
  .es-testimonials__card { padding: 24px 20px; }
}

@media (prefers-reduced-motion: reduce) {
  .es-testimonials__card { transition: none; }
}
</style>

{% schema %}
{
  "name": "Testimonials",
  "class": "index-section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label",
      "default": "Customer Reviews"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "Loved by Fragrance Enthusiasts"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA label",
      "default": "Read All Reviews"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA URL"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background colour",
      "default": "#071321"
    },
    {
      "type": "color",
      "id": "gold_color",
      "label": "Accent colour",
      "default": "#C9A646"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text colour",
      "default": "#ffffff"
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "textarea",
          "id": "review_text",
          "label": "Review text",
          "default": "Absolutely incredible fragrance. The oud is rich and authentic — nothing like the synthetic copies I've tried elsewhere. My partner hasn't stopped complimenting me since I started wearing it. Eterna Scents is now my go-to for every occasion."
        },
        {
          "type": "range",
          "id": "stars",
          "label": "Star rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        },
        {
          "type": "text",
          "id": "name",
          "label": "Customer name",
          "default": "Sarah M."
        },
        {
          "type": "text",
          "id": "location",
          "label": "Location / product",
          "default": "London, UK"
        },
        {
          "type": "image_picker",
          "id": "avatar",
          "label": "Customer photo (optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials",
      "category": "HOME",
      "blocks": [
        {
          "type": "review",
          "settings": {
            "review_text": "Absolutely stunning fragrance. The oud is rich and authentic — nothing like the synthetic copies I've tried elsewhere. Eterna Scents is my go-to now.",
            "stars": 5,
            "name": "Sarah M.",
            "location": "London, UK"
          }
        },
        {
          "type": "review",
          "settings": {
            "review_text": "Bought as a gift for my husband and he absolutely loves it. The packaging alone is worth it — beautifully presented and arrived within 2 days. Will definitely order again.",
            "stars": 5,
            "name": "Aisha K.",
            "location": "Birmingham, UK"
          }
        },
        {
          "type": "review",
          "settings": {
            "review_text": "I was sceptical about ordering Arabian perfume online, but Eterna Scents completely exceeded my expectations. The Lattafa selection is exceptional and the prices are very fair.",
            "stars": 5,
            "name": "James T.",
            "location": "Manchester, UK"
          }
        }
      ]
    }
  ]
}
{% endschema %}
