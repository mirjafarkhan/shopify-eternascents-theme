{%- comment -%}
  sections/es-hero-gallery.liquid
  Full-width auto-advancing hero slideshow — EternaScents luxury style.
  Replaces the old panel-strip layout. Each block = one full-bleed slide.
{%- endcomment -%}

{%- assign height   = section.settings.hero_height | default: 640 -%}
{%- assign speed    = section.settings.autoplay_speed | default: 4000 -%}
{%- assign trans    = section.settings.transition | default: 'fade' -%}
{%- assign autoplay = section.settings.autoplay | default: true -%}

{%- assign slide_blocks  = section.blocks | where: 'type', 'slide' -%}
{%- assign bottle_blocks = section.blocks | where: 'type', 'bottle' -%}
{%- if slide_blocks.size == 0 -%}
  {%- assign slide_blocks = bottle_blocks -%}
{%- endif -%}

<section
  id="es-hs-{{ section.id }}"
  data-section-id="{{ section.id }}"
  data-section-type="es-hero-gallery"
  class="es-hs"
  style="--es-hs-height: {{ height }}px;"
  aria-label="Hero slideshow">

  {%- comment -%} Slide track {%- endcomment -%}
  <div
    class="es-hs__track"
    data-es-slider
    data-autoplay="{{ autoplay }}"
    data-speed="{{ speed }}"
    data-transition="{{ trans }}"
    aria-live="polite">

    {%- if slide_blocks.size > 0 -%}
      {%- for block in slide_blocks -%}
        {%- assign img      = block.settings.image -%}
        {%- assign alt_text = block.settings.alt | default: block.settings.image_alt | default: 'EternaScents luxury fragrance' -%}
        {%- assign dim      = block.settings.dim_opacity | default: 50 -%}

        <div class="es-hs__slide" {{ block.shopify_attributes }}
          role="group"
          aria-label="Slide {{ forloop.index }} of {{ slide_blocks.size }}">

          <div class="es-hs__slide-bg" aria-hidden="true">
            {%- if img != blank -%}
              <img
                src="{{ img | image_url: width: 1920 }}"
                alt="{{ alt_text | escape }}"
                width="1920"
                height="{{ height }}"
                loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                fetchpriority="{% if forloop.first %}high{% else %}auto{% endif %}"
                decoding="async"
                class="es-hs__slide-img">
            {%- else -%}
              <div class="es-hs__slide-placeholder"></div>
            {%- endif -%}
            <div class="es-hs__slide-dim" style="opacity: {{ dim | times: 1 | divided_by: 100.0 }};"></div>
          </div>

          {%- assign badge = block.settings.badge | default: '' -%}
          {%- if badge != blank -%}
            <div class="es-hs__badge">{{ badge }}</div>
          {%- endif -%}

        </div>
      {%- endfor -%}
    {%- else -%}
      <div class="es-hs__slide">
        <div class="es-hs__slide-bg" aria-hidden="true">
          <div class="es-hs__slide-placeholder"></div>
        </div>
      </div>
    {%- endif -%}

  </div>

  {%- comment -%} Text overlay — sits above all slides {%- endcomment -%}
  <div class="es-hs__overlay">
    <div class="es-hs__overlay-inner">

      {%- if section.settings.eyebrow != blank -%}
        <p class="es-hs__eyebrow">
          <span aria-hidden="true">&#9670;</span>
          {{ section.settings.eyebrow }}
          <span aria-hidden="true">&#9670;</span>
        </p>
      {%- endif -%}

      {%- if section.settings.title != blank -%}
        <h1 class="es-hs__title">{{ section.settings.title }}</h1>
      {%- endif -%}

      {%- if section.settings.subtitle != blank -%}
        <p class="es-hs__sub">{{ section.settings.subtitle }}</p>
      {%- endif -%}

      <div class="es-hs__divider" aria-hidden="true">
        <span class="es-hs__divider-line"></span>
        <svg viewBox="0 0 10 10" fill="#C9A646" width="8" height="8"><polygon points="5,0 10,5 5,10 0,5"/></svg>
        <span class="es-hs__divider-line"></span>
      </div>

      <div class="es-hs__ctas">
        {%- if section.settings.btn1_label != blank -%}
          <a href="{{ section.settings.btn1_url | default: '/collections/all' }}" class="es-hs__btn es-hs__btn--primary">
            {{ section.settings.btn1_label }}
          </a>
        {%- endif -%}
        {%- if section.settings.btn2_label != blank -%}
          <a href="{{ section.settings.btn2_url | default: '/collections' }}" class="es-hs__btn es-hs__btn--ghost">
            {{ section.settings.btn2_label }}
          </a>
        {%- endif -%}
      </div>

      {%- if section.settings.show_trust -%}
        <div class="es-hs__trust">
          <span>
            <svg viewBox="0 0 14 14" fill="none" stroke="#C9A646" stroke-width="1.5" width="11" height="11"><path d="M7 1l1.6 3.3 3.6.5-2.6 2.5.6 3.6L7 9.2 3.8 11l.6-3.6L2 5l3.6-.5z"/></svg>
            100% Authentic
          </span>
          <span class="es-hs__trust-dot" aria-hidden="true">&#9670;</span>
          <span>
            <svg viewBox="0 0 14 14" fill="none" stroke="#C9A646" stroke-width="1.5" width="11" height="11"><path d="M1 4h12v7a1 1 0 01-1 1H2a1 1 0 01-1-1V4zm2-1l1-2h6l1 2"/></svg>
            Free UK Delivery
          </span>
          <span class="es-hs__trust-dot" aria-hidden="true">&#9670;</span>
          <span>
            <svg viewBox="0 0 14 14" fill="none" stroke="#C9A646" stroke-width="1.5" width="11" height="11"><path d="M11 3H3a1 1 0 00-1 1v6a1 1 0 001 1h8a1 1 0 001-1V4a1 1 0 00-1-1zM7 5v4M5 7h4"/></svg>
            Gift Wrapped
          </span>
        </div>
      {%- endif -%}

    </div>
  </div>

  {%- comment -%} Navigation {%- endcomment -%}
  <div class="es-hs__nav" aria-label="Slideshow navigation">
    <button class="es-hs__arrow" data-es-prev aria-label="Previous slide">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="20" height="20"><path d="M15 18l-6-6 6-6"/></svg>
    </button>
    <div class="es-hs__dots" data-es-dots role="tablist"></div>
    <button class="es-hs__arrow" data-es-next aria-label="Next slide">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="20" height="20"><path d="M9 18l6-6-6-6"/></svg>
    </button>
  </div>

  <div class="es-hs__fade-bottom" aria-hidden="true"></div>

</section>

<style>
.es-hs {
  position: relative;
  width: 100%;
  height: var(--es-hs-height, 640px);
  overflow: hidden;
  background: #071321;
}

.es-hs__track {
  position: absolute;
  inset: 0;
}

.es-hs__track .slick-list,
.es-hs__track .slick-track {
  height: 100%;
}

.es-hs__slide {
  position: relative;
  width: 100%;
  height: var(--es-hs-height, 640px);
  overflow: hidden;
}

.es-hs__slide-bg {
  position: absolute;
  inset: 0;
}

.es-hs__slide-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
  display: block;
  transition: transform 7s ease;
}

.slick-active .es-hs__slide-img {
  transform: scale(1.05);
}

.es-hs__slide-placeholder {
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, #071321 0%, #0d2035 100%);
}

.es-hs__slide-dim {
  position: absolute;
  inset: 0;
  background: #071321;
}

.es-hs__badge {
  position: absolute;
  top: 24px;
  left: 40px;
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: #C9A646;
  z-index: 2;
}

.es-hs__overlay {
  position: absolute;
  inset: 0;
  z-index: 10;
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: none;
}

.es-hs__overlay-inner {
  pointer-events: auto;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 18px;
  text-align: center;
  padding: 40px 24px;
  max-width: 800px;
  width: 100%;
}

.es-hs__eyebrow {
  display: flex;
  align-items: center;
  gap: 10px;
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.28em;
  text-transform: uppercase;
  color: #C9A646;
  margin: 0;
}

.es-hs__title {
  font-family: 'Playfair Display', Georgia, serif;
  font-size: clamp(36px, 6vw, 76px);
  font-weight: 700;
  color: #fff;
  margin: 0;
  line-height: 1.05;
  text-shadow: 0 4px 32px rgba(7,19,33,0.9);
}

.es-hs__sub {
  font-size: clamp(14px, 1.7vw, 18px);
  color: rgba(255,255,255,0.72);
  margin: 0;
  font-weight: 300;
  line-height: 1.65;
  max-width: 520px;
  text-shadow: 0 2px 12px rgba(7,19,33,0.8);
}

.es-hs__divider {
  display: flex;
  align-items: center;
  gap: 12px;
}

.es-hs__divider-line {
  display: block;
  width: 60px;
  height: 1px;
  background: linear-gradient(90deg, transparent, #C9A646, transparent);
}

.es-hs__ctas {
  display: flex;
  flex-wrap: wrap;
  gap: 14px;
  justify-content: center;
}

.es-hs__btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 15px 44px;
  font-size: 11px;
  font-weight: 800;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  text-decoration: none;
  border: 2px solid transparent;
  transition: background 0.25s, color 0.25s, border-color 0.25s, transform 0.2s;
  white-space: nowrap;
}

.es-hs__btn--primary {
  background: #C9A646;
  color: #071321;
  border-color: #C9A646;
}

.es-hs__btn--primary:hover {
  background: #e0b84f;
  transform: translateY(-2px);
}

.es-hs__btn--ghost {
  background: transparent;
  color: #fff;
  border-color: rgba(255,255,255,0.5);
}

.es-hs__btn--ghost:hover {
  border-color: #C9A646;
  color: #C9A646;
  transform: translateY(-2px);
}

.es-hs__trust {
  display: flex;
  align-items: center;
  gap: 14px;
  flex-wrap: wrap;
  justify-content: center;
  font-size: 11px;
  color: rgba(255,255,255,0.55);
  letter-spacing: 0.05em;
}

.es-hs__trust span {
  display: flex;
  align-items: center;
  gap: 5px;
}

.es-hs__trust-dot {
  font-size: 6px;
  color: #C9A646;
  opacity: 0.7;
}

.es-hs__nav {
  position: absolute;
  bottom: 28px;
  left: 50%;
  transform: translateX(-50%);
  z-index: 20;
  display: flex;
  align-items: center;
  gap: 16px;
}

.es-hs__arrow {
  width: 40px;
  height: 40px;
  border: 1px solid rgba(201,166,70,0.4);
  background: rgba(7,19,33,0.6);
  color: #C9A646;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: background 0.25s, border-color 0.25s;
  backdrop-filter: blur(4px);
  -webkit-backdrop-filter: blur(4px);
}

.es-hs__arrow:hover {
  background: rgba(201,166,70,0.15);
  border-color: #C9A646;
}

.es-hs__dots {
  display: flex;
  gap: 8px;
  align-items: center;
}

.es-hs__track .slick-dots {
  display: none !important;
}

.es-hs-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: rgba(255,255,255,0.3);
  border: none;
  cursor: pointer;
  padding: 0;
  transition: background 0.25s, width 0.25s;
  display: block;
}

.es-hs-dot.is-active {
  background: #C9A646;
  width: 24px;
  border-radius: 4px;
}

.es-hs__fade-bottom {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100px;
  background: linear-gradient(to bottom, transparent, rgba(7,19,33,0.5));
  z-index: 5;
  pointer-events: none;
}

@media (max-width: 768px) {
  .es-hs { height: 520px; --es-hs-height: 520px; }
  .es-hs__slide { height: 520px; }
  .es-hs__overlay-inner { gap: 14px; padding: 24px 20px; }
  .es-hs__btn { padding: 13px 28px; }
  .es-hs__trust-dot { display: none; }
  .es-hs__trust { flex-direction: column; gap: 6px; }
  .es-hs__badge { left: 20px; top: 16px; }
}

@media (max-width: 480px) {
  .es-hs { height: 460px; --es-hs-height: 460px; }
  .es-hs__slide { height: 460px; }
  .es-hs__ctas { flex-direction: column; align-items: center; }
  .es-hs__btn { width: 220px; justify-content: center; }
}

@media (prefers-reduced-motion: reduce) {
  .slick-active .es-hs__slide-img { transform: none; }
  .es-hs__btn,
  .es-hs-dot { transition: none; }
}
</style>

<script>
(function() {
  function initSlider() {
    var section = document.getElementById('es-hs-{{ section.id }}');
    if (!section) return;

    var track   = section.querySelector('[data-es-slider]');
    var dotsWrap = section.querySelector('[data-es-dots]');
    var prevBtn  = section.querySelector('[data-es-prev]');
    var nextBtn  = section.querySelector('[data-es-next]');

    if (!track || typeof jQuery === 'undefined' || typeof jQuery.fn.slick === 'undefined') return;

    var $track    = jQuery(track);
    var isAutoplay = track.getAttribute('data-autoplay') !== 'false';
    var spd       = parseInt(track.getAttribute('data-speed')) || 4000;
    var isFade    = (track.getAttribute('data-transition') || 'fade') === 'fade';

    $track.slick({
      autoplay:       isAutoplay,
      autoplaySpeed:  spd,
      fade:           isFade,
      cssEase:        'cubic-bezier(0.4,0,0.2,1)',
      speed:          900,
      arrows:         false,
      dots:           false,
      pauseOnHover:   true,
      infinite:       true,
      adaptiveHeight: false
    });

    var total = $track.slick('getSlick').slideCount;
    for (var i = 0; i < total; i++) {
      var dot = document.createElement('button');
      dot.className = 'es-hs-dot' + (i === 0 ? ' is-active' : '');
      dot.setAttribute('role', 'tab');
      dot.setAttribute('aria-label', 'Go to slide ' + (i + 1));
      dot.setAttribute('data-idx', i);
      dotsWrap.appendChild(dot);
    }

    dotsWrap.addEventListener('click', function(e) {
      var btn = e.target.closest('.es-hs-dot');
      if (btn) $track.slick('slickGoTo', parseInt(btn.getAttribute('data-idx')));
    });

    prevBtn.addEventListener('click', function() { $track.slick('slickPrev'); });
    nextBtn.addEventListener('click', function() { $track.slick('slickNext'); });

    $track.on('afterChange', function(e, slick, current) {
      dotsWrap.querySelectorAll('.es-hs-dot').forEach(function(d, idx) {
        d.classList.toggle('is-active', idx === current);
      });
    });
  }

  function tryInit() {
    if (typeof jQuery !== 'undefined' && typeof jQuery.fn.slick !== 'undefined') {
      jQuery(initSlider);
    } else {
      setTimeout(tryInit, 150);
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', tryInit);
  } else {
    tryInit();
  }
})();
</script>

{% schema %}
{
  "name": "Hero — Gallery Strip",
  "class": "index-section",
  "settings": [
    {
      "type": "header",
      "content": "Text overlay"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label",
      "default": "Authentic Arabian Perfumery"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Headline (H1)",
      "default": "The Art of Arabian Fragrance"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subheadline",
      "default": "Luxury oud, rose & amber — delivered across the UK"
    },
    {
      "type": "header",
      "content": "Buttons"
    },
    {
      "type": "text",
      "id": "btn1_label",
      "label": "Primary button label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "btn1_url",
      "label": "Primary button URL"
    },
    {
      "type": "text",
      "id": "btn2_label",
      "label": "Secondary button label",
      "default": "Explore Brands"
    },
    {
      "type": "url",
      "id": "btn2_url",
      "label": "Secondary button URL"
    },
    {
      "type": "header",
      "content": "Slideshow settings"
    },
    {
      "type": "select",
      "id": "transition",
      "label": "Transition style",
      "options": [
        { "value": "fade", "label": "Fade" },
        { "value": "slide", "label": "Slide" }
      ],
      "default": "fade"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Auto-play",
      "default": true
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "label": "Time per slide (ms)",
      "min": 2000,
      "max": 8000,
      "step": 500,
      "default": 4000
    },
    {
      "type": "range",
      "id": "hero_height",
      "label": "Hero height (px)",
      "min": 400,
      "max": 900,
      "step": 20,
      "default": 640
    },
    {
      "type": "checkbox",
      "id": "show_trust",
      "label": "Show trust badges",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Slide image",
          "info": "Landscape, min 1920x640px recommended."
        },
        {
          "type": "text",
          "id": "image_alt",
          "label": "Image alt text",
          "default": "Luxury Arabian fragrance collection"
        },
        {
          "type": "range",
          "id": "dim_opacity",
          "label": "Image darkness",
          "min": 20,
          "max": 80,
          "step": 5,
          "default": 50,
          "unit": "%"
        },
        {
          "type": "text",
          "id": "badge",
          "label": "Collection badge (optional)"
        }
      ]
    },
    {
      "type": "bottle",
      "name": "Bottle Panel",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "alt",
          "label": "Image alt text",
          "default": "EternaScents luxury fragrance"
        },
        {
          "type": "range",
          "id": "dim_opacity",
          "label": "Image darkness",
          "min": 20,
          "max": 80,
          "step": 5,
          "default": 50,
          "unit": "%"
        },
        {
          "type": "text",
          "id": "badge",
          "label": "Collection badge (optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero — Gallery Strip",
      "category": "HOME",
      "blocks": [
        { "type": "slide" },
        { "type": "slide" },
        { "type": "slide" }
      ]
    }
  ]
}
{% endschema %}
