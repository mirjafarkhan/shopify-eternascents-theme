{%- comment -%}
  sections/es-newsletter.liquid
  Premium newsletter signup — Shopify native customer email form.
  Split layout: ornamental gold pattern left, form right.
  No external dependencies. CSS animations only.
{%- endcomment -%}

{%- assign bg   = section.settings.bg_color   | default: '#0d1e2e' -%}
{%- assign gold = section.settings.gold_color  | default: '#C9A646' -%}
{%- assign text = section.settings.text_color  | default: '#ffffff' -%}

<section
  data-section-id="{{ section.id }}"
  data-section-type="es-newsletter"
  class="es-newsletter"
  style="background: {{ bg }};"
  aria-label="Newsletter signup">

  <div class="es-newsletter__inner">

    {%- comment -%} Decorative side {%- endcomment -%}
    <div class="es-newsletter__deco" aria-hidden="true">
      <div class="es-newsletter__deco-circle es-newsletter__deco-circle--1" style="border-color: {{ gold }};"></div>
      <div class="es-newsletter__deco-circle es-newsletter__deco-circle--2" style="border-color: {{ gold }};"></div>
      <svg class="es-newsletter__deco-ornament" viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path d="M100 20C55.8 20 20 55.8 20 100s35.8 80 80 80 80-35.8 80-80S144.2 20 100 20zm0 8c39.8 0 72 32.2 72 72s-32.2 72-72 72-72-32.2-72-72 32.2-72 72-72z" fill="{{ gold }}" fill-opacity="0.08"/>
        <path d="M100 40c-33.1 0-60 26.9-60 60s26.9 60 60 60 60-26.9 60-60-26.9-60-60-60zm0 8c28.7 0 52 23.3 52 52s-23.3 52-52 52-52-23.3-52-52 23.3-52 52-52z" fill="{{ gold }}" fill-opacity="0.06"/>
        <path d="M100 60c-22.1 0-40 17.9-40 40s17.9 40 40 40 40-17.9 40-40-17.9-40-40-40zm0 8c17.7 0 32 14.3 32 32s-14.3 32-32 32-32-14.3-32-32 14.3-32 32-32z" fill="{{ gold }}" fill-opacity="0.04"/>
        <circle cx="100" cy="100" r="6" fill="{{ gold }}" fill-opacity="0.3"/>
        <line x1="100" y1="20" x2="100" y2="180" stroke="{{ gold }}" stroke-opacity="0.08" stroke-width="1"/>
        <line x1="20" y1="100" x2="180" y2="100" stroke="{{ gold }}" stroke-opacity="0.08" stroke-width="1"/>
        <line x1="43" y1="43" x2="157" y2="157" stroke="{{ gold }}" stroke-opacity="0.05" stroke-width="1"/>
        <line x1="157" y1="43" x2="43" y2="157" stroke="{{ gold }}" stroke-opacity="0.05" stroke-width="1"/>
      </svg>
      <p class="es-newsletter__deco-text" style="color: {{ gold }};">Eterna Scents</p>
    </div>

    {%- comment -%} Form side {%- endcomment -%}
    <div class="es-newsletter__form-col es-reveal">

      {%- if section.settings.eyebrow != blank -%}
        <p class="es-newsletter__eyebrow" style="color: {{ gold }};">{{ section.settings.eyebrow }}</p>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h2 class="es-newsletter__heading" style="color: {{ text }};">{{ section.settings.heading }}</h2>
      {%- endif -%}

      {%- if section.settings.description != blank -%}
        <p class="es-newsletter__desc" style="color: rgba(255,255,255,0.65);">{{ section.settings.description }}</p>
      {%- endif -%}

      {%- form 'customer', id: 'es-newsletter-form', class: 'es-newsletter__form' -%}
        <input type="hidden" name="contact[tags]" value="newsletter">

        {%- if form.posted_successfully? -%}
          <div class="es-newsletter__success" role="alert" style="color: {{ gold }};">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20" aria-hidden="true"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            {{ section.settings.success_message | default: "Thank you! You've been added to our list. Expect a welcome gift soon." }}
          </div>
        {%- elsif form.errors -%}
          <div class="es-newsletter__error" role="alert" style="color: #e07070;">
            {{ form.errors | default_errors }}
          </div>
        {%- endif -%}

        <div class="es-newsletter__field-wrap">
          <label for="es-newsletter-email" class="visually-hidden">Email address</label>
          <input
            type="email"
            name="contact[email]"
            id="es-newsletter-email"
            class="es-newsletter__input"
            placeholder="{{ section.settings.placeholder | default: 'Your email address' }}"
            autocomplete="email"
            required
            aria-required="true"
            style="border-color: rgba(201,166,70,0.3); color: {{ text }}; background: rgba(255,255,255,0.06);">
          <button
            type="submit"
            class="es-newsletter__submit"
            style="background: {{ gold }}; color: #071321;">
            {{ section.settings.btn_label | default: 'Subscribe' }}
          </button>
        </div>

        {%- if section.settings.disclaimer != blank -%}
          <p class="es-newsletter__disclaimer" style="color: rgba(255,255,255,0.35);">{{ section.settings.disclaimer }}</p>
        {%- endif -%}

      {%- endform -%}

      {%- if section.settings.show_perks -%}
        <ul class="es-newsletter__perks" role="list" aria-label="Subscriber benefits">
          <li class="es-newsletter__perk" style="color: rgba(255,255,255,0.6);">
            <svg viewBox="0 0 16 16" fill="{{ gold }}" width="12" height="12" aria-hidden="true"><path d="M8 .5a7.5 7.5 0 100 15A7.5 7.5 0 008 .5zm3.47 5.78l-4 4a.75.75 0 01-1.06 0l-1.5-1.5a.75.75 0 111.06-1.06l.97.97 3.47-3.47a.75.75 0 011.06 1.06z"/></svg>
            10% off your first order
          </li>
          <li class="es-newsletter__perk" style="color: rgba(255,255,255,0.6);">
            <svg viewBox="0 0 16 16" fill="{{ gold }}" width="12" height="12" aria-hidden="true"><path d="M8 .5a7.5 7.5 0 100 15A7.5 7.5 0 008 .5zm3.47 5.78l-4 4a.75.75 0 01-1.06 0l-1.5-1.5a.75.75 0 111.06-1.06l.97.97 3.47-3.47a.75.75 0 011.06 1.06z"/></svg>
            New arrivals &amp; exclusive offers
          </li>
          <li class="es-newsletter__perk" style="color: rgba(255,255,255,0.6);">
            <svg viewBox="0 0 16 16" fill="{{ gold }}" width="12" height="12" aria-hidden="true"><path d="M8 .5a7.5 7.5 0 100 15A7.5 7.5 0 008 .5zm3.47 5.78l-4 4a.75.75 0 01-1.06 0l-1.5-1.5a.75.75 0 111.06-1.06l.97.97 3.47-3.47a.75.75 0 011.06 1.06z"/></svg>
            Expert fragrance guides &amp; tips
          </li>
        </ul>
      {%- endif -%}

    </div>

  </div>

</section>

<style>
.es-newsletter {
  padding: 80px 0;
  position: relative;
  overflow: hidden;
}

.es-newsletter::before {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(ellipse at 10% 50%, rgba(201,166,70,0.05) 0%, transparent 55%);
  pointer-events: none;
}

.es-newsletter__inner {
  max-width: 1100px;
  margin: 0 auto;
  padding: 0 32px;
  display: grid;
  grid-template-columns: 1fr 1.4fr;
  gap: 64px;
  align-items: center;
}

/* ─── Decorative side ────────────────────────────────────────────────── */
.es-newsletter__deco {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 280px;
}

.es-newsletter__deco-circle {
  position: absolute;
  border: 1px solid;
  border-radius: 50%;
  opacity: 0.15;
}

.es-newsletter__deco-circle--1 {
  width: 220px;
  height: 220px;
  animation: es-rotate 20s linear infinite;
}

.es-newsletter__deco-circle--2 {
  width: 160px;
  height: 160px;
  animation: es-rotate 14s linear infinite reverse;
}

.es-newsletter__deco-ornament {
  width: 200px;
  height: 200px;
}

.es-newsletter__deco-text {
  position: absolute;
  bottom: 24px;
  font-family: 'Playfair Display', Georgia, serif;
  font-size: 13px;
  font-weight: 700;
  letter-spacing: 0.3em;
  text-transform: uppercase;
  margin: 0;
}

@keyframes es-rotate {
  from { transform: rotate(0deg); }
  to   { transform: rotate(360deg); }
}

/* ─── Form side ──────────────────────────────────────────────────────── */
.es-newsletter__form-col {
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.es-newsletter__eyebrow {
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  margin: 0;
}

.es-newsletter__heading {
  font-family: 'Playfair Display', Georgia, serif;
  font-size: clamp(24px, 2.8vw, 38px);
  font-weight: 700;
  margin: 0;
  line-height: 1.2;
}

.es-newsletter__desc {
  font-size: 15px;
  line-height: 1.7;
  margin: 0;
}

/* ─── Form ───────────────────────────────────────────────────────────── */
.es-newsletter__form { display: flex; flex-direction: column; gap: 12px; }

.es-newsletter__field-wrap {
  display: flex;
  gap: 0;
  border: 1px solid rgba(201,166,70,0.3);
  overflow: hidden;
}

.es-newsletter__input {
  flex: 1;
  border: none;
  outline: none;
  padding: 14px 20px;
  font-size: 14px;
  background: rgba(255,255,255,0.06);
  min-width: 0;
}

.es-newsletter__input::placeholder {
  color: rgba(255,255,255,0.35);
}

.es-newsletter__input:focus {
  background: rgba(255,255,255,0.1);
}

.es-newsletter__submit {
  flex-shrink: 0;
  padding: 14px 28px;
  border: none;
  cursor: pointer;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  transition: filter 0.2s, transform 0.2s;
  white-space: nowrap;
}

.es-newsletter__submit:hover {
  filter: brightness(1.1);
}

.es-newsletter__submit:focus-visible {
  outline: 2px solid #C9A646;
  outline-offset: 2px;
}

.es-newsletter__disclaimer {
  font-size: 11px;
  line-height: 1.6;
  margin: 0;
}

/* ─── Status messages ────────────────────────────────────────────────── */
.es-newsletter__success,
.es-newsletter__error {
  display: flex;
  align-items: flex-start;
  gap: 8px;
  font-size: 14px;
  padding: 12px 0;
}

/* ─── Perks list ─────────────────────────────────────────────────────── */
.es-newsletter__perks {
  list-style: none;
  padding: 0;
  margin: 8px 0 0;
  display: flex;
  flex-wrap: wrap;
  gap: 8px 24px;
}

.es-newsletter__perk {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 13px;
}

/* ─── Visually hidden ────────────────────────────────────────────────── */
.visually-hidden {
  position: absolute;
  width: 1px;
  height: 1px;
  padding: 0;
  margin: -1px;
  overflow: hidden;
  clip: rect(0,0,0,0);
  white-space: nowrap;
  border: 0;
}

/* ─── Mobile ─────────────────────────────────────────────────────────── */
@media (max-width: 768px) {
  .es-newsletter { padding: 56px 0; }
  .es-newsletter__inner {
    grid-template-columns: 1fr;
    gap: 32px;
    padding: 0 20px;
  }
  .es-newsletter__deco { height: 140px; }
  .es-newsletter__deco-circle--1 { width: 130px; height: 130px; }
  .es-newsletter__deco-circle--2 { width: 90px; height: 90px; }
  .es-newsletter__deco-ornament { width: 120px; height: 120px; }
  .es-newsletter__field-wrap { flex-direction: column; }
  .es-newsletter__submit { width: 100%; padding: 14px; }
}

@media (prefers-reduced-motion: reduce) {
  .es-newsletter__deco-circle { animation: none; }
}
</style>

{% schema %}
{
  "name": "Newsletter Signup",
  "class": "index-section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label",
      "default": "Join the Community"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Discover New Fragrances First"
    },
    {
      "type": "text",
      "id": "description",
      "label": "Description",
      "default": "Subscribe for exclusive offers, new Arabian perfume arrivals, and expert fragrance guides. Plus get 10% off your first order."
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Input placeholder",
      "default": "Your email address"
    },
    {
      "type": "text",
      "id": "btn_label",
      "label": "Submit button label",
      "default": "Subscribe"
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "Success message",
      "default": "Thank you! You've been added to our list. Expect a welcome gift soon."
    },
    {
      "type": "text",
      "id": "disclaimer",
      "label": "Disclaimer text",
      "default": "By subscribing you agree to our Privacy Policy. Unsubscribe at any time."
    },
    {
      "type": "checkbox",
      "id": "show_perks",
      "label": "Show subscriber perks list",
      "default": true
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background colour",
      "default": "#0d1e2e"
    },
    {
      "type": "color",
      "id": "gold_color",
      "label": "Accent colour",
      "default": "#C9A646"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text colour",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "Newsletter Signup",
      "category": "HOME"
    }
  ]
}
{% endschema %}
