{%- comment -%}
  sections/es-logo-grid.liquid
  Brand logo grid — EternaScents luxury style.

  Layout: responsive CSS grid of brand logos (grayscale → full colour
  on hover) with a subtle gold underline accent.  Inspired by the
  emiratesoud.co.uk brand strip but in the EternaScents dark/gold palette.

  Supports an optional "Marquee" mode (infinite CSS scroll animation)
  or a static multi-row grid.
{%- endcomment -%}

{%- assign bg      = section.settings.bg_color     | default: '#ffffff' -%}
{%- assign navy    = section.settings.navy_color    | default: '#071321' -%}
{%- assign gold    = section.settings.gold_color    | default: '#C9A646' -%}
{%- assign mode    = section.settings.display_mode  | default: 'grid' -%}

{%- assign logo_blocks = section.blocks | where: 'type', 'logo' -%}

<section
  data-section-id="{{ section.id }}"
  data-section-type="es-logo-grid"
  class="es-lg"
  style="background: {{ bg }}; --es-lg-gold: {{ gold }}; --es-lg-navy: {{ navy }};"
  aria-label="Our fragrance brands">

  <div class="es-lg__inner">

    {%- comment -%} Section header {%- endcomment -%}
    {%- if section.settings.heading != blank -%}
      <div class="es-lg__header es-reveal">
        {%- if section.settings.eyebrow != blank -%}
          <p class="es-lg__eyebrow" style="color: {{ gold }};">{{ section.settings.eyebrow }}</p>
        {%- endif -%}
        <h2 class="es-lg__heading" style="color: {{ navy }};">{{ section.settings.heading }}</h2>
        <div class="es-lg__heading-rule" aria-hidden="true" style="background: {{ gold }};"></div>
      </div>
    {%- endif -%}

    {%- if logo_blocks.size > 0 -%}

      {%- if mode == 'marquee' -%}

        {%- comment -%} ── Marquee / infinite scroll mode ─────────────────── {%- endcomment -%}
        <div class="es-lg__marquee-wrap" aria-label="Brand logos">
          <div class="es-lg__marquee-track">
            {%- comment -%} Duplicate the list so the loop is seamless {%- endcomment -%}
            {%- for pass in (1..2) -%}
              <ul class="es-lg__marquee-list" role="list" aria-hidden="{{ forloop.index | minus: 1 | times: 1 | plus: 0 | lte: 0 | ternary: 'false', 'true' }}">
                {%- for block in logo_blocks -%}
                  {%- if block.type == 'logo' -%}
                    <li class="es-lg__logo-item" {{ block.shopify_attributes }}>
                      <a href="{{ block.settings.url | default: '/collections/all' }}"
                        class="es-lg__logo-link"
                        aria-label="Shop {{ block.settings.name }} perfumes">
                        {%- if block.settings.logo != blank -%}
                          <img
                            src="{{ block.settings.logo | image_url: width: 240 }}"
                            alt="{{ block.settings.name | escape }}"
                            width="120"
                            height="60"
                            loading="lazy"
                            class="es-lg__logo-img">
                        {%- else -%}
                          <span class="es-lg__logo-text" style="color: {{ navy }};">{{ block.settings.name }}</span>
                        {%- endif -%}
                      </a>
                    </li>
                  {%- endif -%}
                {%- endfor -%}
              </ul>
            {%- endfor -%}
          </div>
        </div>

      {%- else -%}

        {%- comment -%} ── Static grid mode ────────────────────────────────── {%- endcomment -%}
        <ul class="es-lg__grid es-reveal" role="list" aria-label="Brand logos">
          {%- for block in logo_blocks -%}
            {%- if block.type == 'logo' -%}
              <li class="es-lg__logo-item" {{ block.shopify_attributes }}
                style="--es-delay: {{ forloop.index0 | times: 40 }}ms;">
                <a href="{{ block.settings.url | default: '/collections/all' }}"
                  class="es-lg__logo-link"
                  aria-label="Shop {{ block.settings.name }} perfumes">
                  {%- if block.settings.logo != blank -%}
                    <img
                      src="{{ block.settings.logo | image_url: width: 240 }}"
                      alt="{{ block.settings.name | escape }}"
                      width="120"
                      height="60"
                      loading="lazy"
                      class="es-lg__logo-img">
                  {%- else -%}
                    <span class="es-lg__logo-text" style="color: {{ navy }};">{{ block.settings.name }}</span>
                  {%- endif -%}
                </a>
              </li>
            {%- endif -%}
          {%- endfor -%}
        </ul>

      {%- endif -%}

    {%- endif -%}

  </div>

</section>

<style>
/* ─── Section ────────────────────────────────────────────────────────── */
.es-lg {
  padding: 52px 0;
  border-top: 1px solid rgba(201,166,70,0.12);
  border-bottom: 1px solid rgba(201,166,70,0.12);
}

.es-lg__inner {
  max-width: 1360px;
  margin: 0 auto;
  padding: 0 32px;
}

/* ─── Header ─────────────────────────────────────────────────────────── */
.es-lg__header {
  text-align: center;
  margin-bottom: 36px;
}

.es-lg__eyebrow {
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.24em;
  text-transform: uppercase;
  margin: 0 0 8px;
}

.es-lg__heading {
  font-family: 'Playfair Display', Georgia, serif;
  font-size: clamp(20px, 2.5vw, 32px);
  font-weight: 700;
  margin: 0 0 14px;
}

.es-lg__heading-rule {
  width: 40px;
  height: 2px;
  margin: 0 auto;
}

/* ─── Static grid ────────────────────────────────────────────────────── */
.es-lg__grid {
  list-style: none;
  margin: 0;
  padding: 0;
  display: grid;
  grid-template-columns: repeat(6, 1fr);
  gap: 0;
}

/* ─── Logo item (shared grid + marquee) ──────────────────────────────── */
.es-lg__logo-item {
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1px solid rgba(201,166,70,0.1);
  margin: -1px 0 0 -1px; /* collapse borders */
}

/* ─── Logo link ──────────────────────────────────────────────────────── */
.es-lg__logo-link {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24px 20px;
  width: 100%;
  height: 100%;
  min-height: 88px;
  text-decoration: none;
  position: relative;
  transition: background 0.25s;
}

.es-lg__logo-link::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 2px;
  background: var(--es-lg-gold, #C9A646);
  transform: scaleX(0);
  transition: transform 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  transform-origin: center;
}

.es-lg__logo-link:hover {
  background: rgba(201,166,70,0.05);
}

.es-lg__logo-link:hover::after {
  transform: scaleX(1);
}

/* ─── Logo image ─────────────────────────────────────────────────────── */
.es-lg__logo-img {
  max-width: 120px;
  max-height: 56px;
  width: auto;
  height: auto;
  object-fit: contain;
  display: block;
  filter: grayscale(100%) opacity(0.65);
  transition: filter 0.3s, transform 0.3s;
}

.es-lg__logo-link:hover .es-lg__logo-img {
  filter: grayscale(0%) opacity(1);
  transform: scale(1.06);
}

/* ─── Text fallback ──────────────────────────────────────────────────── */
.es-lg__logo-text {
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  text-align: center;
  line-height: 1.3;
}

/* ─── Marquee mode ───────────────────────────────────────────────────── */
.es-lg__marquee-wrap {
  overflow: hidden;
  position: relative;
}

.es-lg__marquee-wrap::before,
.es-lg__marquee-wrap::after {
  content: '';
  position: absolute;
  top: 0;
  bottom: 0;
  width: 80px;
  z-index: 2;
  pointer-events: none;
}

.es-lg__marquee-wrap::before {
  left: 0;
  background: linear-gradient(to right, var(--bg, #ffffff), transparent);
}

.es-lg__marquee-wrap::after {
  right: 0;
  background: linear-gradient(to left, var(--bg, #ffffff), transparent);
}

.es-lg__marquee-track {
  display: flex;
  width: max-content;
  animation: es-marquee 30s linear infinite;
}

.es-lg__marquee-list {
  display: flex;
  align-items: center;
  list-style: none;
  margin: 0;
  padding: 0;
  gap: 0;
}

.es-lg__marquee-list .es-lg__logo-item {
  border: none;
  margin: 0;
}

.es-lg__marquee-list .es-lg__logo-link {
  min-width: 160px;
  border-right: 1px solid rgba(201,166,70,0.1);
}

@keyframes es-marquee {
  from { transform: translateX(0); }
  to   { transform: translateX(-50%); }
}

.es-lg__marquee-wrap:hover .es-lg__marquee-track {
  animation-play-state: paused;
}

/* ─── Responsive grid ────────────────────────────────────────────────── */
@media (max-width: 1100px) {
  .es-lg__grid { grid-template-columns: repeat(5, 1fr); }
}

@media (max-width: 860px) {
  .es-lg__grid { grid-template-columns: repeat(4, 1fr); }
  .es-lg { padding: 36px 0; }
  .es-lg__inner { padding: 0 16px; }
}

@media (max-width: 600px) {
  .es-lg__grid { grid-template-columns: repeat(3, 1fr); }
  .es-lg__logo-link { padding: 16px 12px; min-height: 70px; }
  .es-lg__logo-img { max-width: 80px; max-height: 40px; }
}

@media (max-width: 400px) {
  .es-lg__grid { grid-template-columns: repeat(2, 1fr); }
}

/* ─── Reduced motion ─────────────────────────────────────────────────── */
@media (prefers-reduced-motion: reduce) {
  .es-lg__marquee-track { animation: none; }
  .es-lg__logo-img,
  .es-lg__logo-link,
  .es-lg__logo-link::after { transition: none; }
}
</style>

{% schema %}
{
  "name": "Brand Logo Grid",
  "class": "index-section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label",
      "default": "Trusted Brands"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading (leave blank to hide)",
      "default": "The World's Finest Fragrance Houses"
    },
    {
      "type": "select",
      "id": "display_mode",
      "label": "Display mode",
      "options": [
        { "value": "grid", "label": "Static grid (multi-row)" },
        { "value": "marquee", "label": "Scrolling marquee (one row)" }
      ],
      "default": "grid"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background colour",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "navy_color",
      "label": "Text colour",
      "default": "#071321"
    },
    {
      "type": "color",
      "id": "gold_color",
      "label": "Accent colour",
      "default": "#C9A646"
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Brand Logo",
      "settings": [
        {
          "type": "text",
          "id": "name",
          "label": "Brand name",
          "default": "Lattafa"
        },
        {
          "type": "image_picker",
          "id": "logo",
          "label": "Logo image",
          "info": "PNG with transparent background recommended. ~240×80px."
        },
        {
          "type": "url",
          "id": "url",
          "label": "Brand collection URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Brand Logo Grid",
      "category": "HOME",
      "blocks": [
        { "type": "logo", "settings": { "name": "Lattafa", "url": "/collections/lattafa-perfumes" } },
        { "type": "logo", "settings": { "name": "Rasasi", "url": "/collections/rasasi" } },
        { "type": "logo", "settings": { "name": "Swiss Arabian", "url": "/collections/swiss-arabian" } },
        { "type": "logo", "settings": { "name": "Ahmed Al Maghribi", "url": "/collections/ahmed-al-magribi" } },
        { "type": "logo", "settings": { "name": "Rayhaan", "url": "/collections/rayhaan" } },
        { "type": "logo", "settings": { "name": "Afnan", "url": "/collections/all" } }
      ]
    }
  ]
}
{% endschema %}
