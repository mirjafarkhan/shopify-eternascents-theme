          "default": "#fff"
        },
        {
          "type": "color",
          "id": "color_quote",
          "label": "Color quote",
          "default": "#fff"
        },
        {
          "type": "text",
          "id": "block_name",
          "label": "Content",
          "default": "DESTINEE"
        },
        {
          "type": "color",
          "id": "color_name",
          "label": "Color Name"
        },
        {
          "type": "text",
          "id": "block_des",
          "label": "Info",
          "default": "Marketing Personal"
        },
        {
          "type": "color",
          "id": "color_des",
