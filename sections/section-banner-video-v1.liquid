      "default": "Become More Confident & Show Your Better Self"
    },
    {
      "type": "color",
      "id": "color_title",
      "label": "Color title",
      "default": "#222"
    },
    {
      "type": "text",
      "id": "desc_banner",
      "label": "Description banner",
      "default": "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Ut elit tellus, luctus nec ullamcorper mattis, pulvinar dapibus leo."
    },
    {
      "type": "color",
      "id": "color_desc",
      "label": "Color description",
      "default": "#222"
    },
    {
      "type": "text",
      "id": "button_name",
      "label": "Button banner",
      "default": "SHOP NOW"
    },
    {
      "type": "color",
      "id": "color_btn",
      "label": "Color button",
      "default": "#fff"
    },
    {
      "type": "color",
      "id": "bg_btn",
      "label": "Background button",
      "default": "#000"
    },
    {
      "type": "color",
      "id": "color_btn_hover",
      "label": "Color button hover",
      "default": "#fff"
    },
    {
      "type": "color",
      "id": "bg_btn_hover",
      "label": "Background button hover",
      "default": "#ff6f00"
