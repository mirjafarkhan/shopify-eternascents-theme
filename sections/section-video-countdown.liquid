<div data-section-id="{{ section.id }}" data-section-type="section-video-countdown-v1" style="{% if section.settings.margin_top != blank %}margin-top: {{section.settings.margin_top}}px;{%endif%} {% if section.settings.margin_bottom != blank %}margin-bottom: {{section.settings.margin_bottom}}px;{% endif %} {% if section.settings.sections_layout == "dark" %}background: {{section.settings.sections_bg_color}};{% endif %}">
  <div class="section-video-countdown-v1 section-video-countdown-v1-{{ section }} mt-all">
    <div class="container container-v2">
      <div class="row align-items-center row-banner-{{ section.id }}">
        <div class="col-12 col-lg-6">
          <div class="section-video">
            <div class="box-video">
              <div class="video-bg">
                {% if section.settings.video_img != blank %}
                <img data-src="{{section.settings.video_img | img_url:'master'}}" class="lazyload img-fluid w-100" alt="_img_banner_">
                {% else %}
                <img data-src="https://via.placeholder.com/800x790" class="lazyload img-fluid w-100" alt="_img_banner_">
                {% endif %}
              </div>
              <div class="video-content">
                <a data-fancybox href="{{section.settings.url_video1}}"> 
                  <span class="box-btn">
                    <span class="btn-banner">
                      <i class="fa fa-play"></i>
                      <span class="line-video line-1"></span>
                      <span class="line-video line-2"></span>
                      <span class="line-video line-3"></span>
                    </span>
                  </span>
                </a>
              </div>
            </div>
          </div>
        </div>
        <div class="col-12 col-lg-6">
          <div class="countdown-content">
            <div class="text-center relative">        	
              {% if section.settings.title_info != blank %}
              <div class="title-info text-center">
                <h2 class="title_heading" style="color: {{section.settings.color_title_info}}">{{section.settings.title_info}}</h2>
              </div>
              {% endif %}
            </div>
            <div class="countdown-item">
              {% for block in section.blocks %}
              {% if block.type == "countdown" %}
              <div class="product product-grid product-item">
                {% if block.settings.select_pd != blank %}
                {% assign product = all_products[block.settings.select_pd] %}
                <div class="row">
                  <div class="col-12 col-sm-6 col-xl-5 pd-image">
                    <a href="{{ product.url | within: collection }}" title="">
                      <img src="{{ product.featured_image.src | img_url: 'large' }}" alt="{{ product.featured_image.alt | escape }}">
                      {% for image in product.images %}     
                      {% if forloop.last == true %}
                      <img src="{{ image.src | product_img_url: 'large' }}" alt="{{ product.featured_image.alt | escape }}">   
                      {%endif%}
                      {% endfor %}
                    </a>
                  </div>
                  <div class="col-12 col-sm-6 col-xl-7 cd-info">
                    {% if block.settings.enable_label_pd %}
                    {% if product.compare_at_price != blank %}
                    {% assign sale = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price %}
                    <label>-{{sale}}%</label>
                    {% endif %}
                    {% endif %}
                    <h4 class="pd-name mb-0"><a href="{{product.url}}">{{product.title}}</a></h4>
                    <div class="product-price">
                      <span class="amout">
                        <del class="sale-price">{{ product.compare_at_price | money }}</del>
                        {% capture price %}{{ product.price | money }}{% endcapture %}
                        <span >{{ price }}</span>
                      </span>
      
                    </div>
                    {% if block.settings.timer != blank %}
                    <ul class="timer" data-countdown="product-countdown" data-date="{{block.settings.timer}}"></ul>
                    {% endif %}
                    {% if block.settings.btn_name != blank %}
                    <div class="">
                      <a class="button-main3" href="{{product.url}}">{{block.settings.btn_name}}</a>
                    </div>
                    {%  endif %}
                  </div>
                </div>
                {% else %}
                <div class="row">
                  <div class="col-12 col-sm-6 col-xl-5 pd-image">
                    <a href="/admin/products"> 
                      {% capture current_1 %}{% cycle 1, 2, 3 %}{% endcapture %}
                      {{ 'product-' | append: current_1 | placeholder_svg_tag: 'placeholder-svg' }}
                    </a>
                    
                  </div>
                  <div class="col-12 col-sm-6 col-xl-7 cd-info">
                    <h4 class="pd-name mb-0"><a href="/admin/products">Example Product</a></h4>
                    <div class="product-price">
                      <span class="amout">
                        <span >$40.00</span>
                      </span>
      
                    </div>
                    {% if block.settings.timer != blank %}
                    <ul class="timer" data-countdown="product-countdown" data-date="{{block.settings.timer}}"></ul>
                    {% endif %}
                    {% if block.settings.btn_name != blank %}
                    <div class="">
                      <a class="button-main3" href="{{product.url}}">{{block.settings.btn_name}}</a>
                    </div>
                    {%  endif %}
                  </div>
                </div>
                {% endif %}
              </div>
              {% endif %}
              {% endfor %}
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .section-video-countdown-v1-{{ section }} .button:hover {
    color : {{section.settings.color_btn_hover}} !important;
    background : {{section.settings.bg_btn_hover}} !important;
  }
  .section-video-countdown-v1-{{ section }} .countdown-timer li span {
    color: {{section.settings.color_countdown}} !important;
  }
  .section-video-countdown-v1-{{ section }} .countdown-timer li {
    color: {{section.settings.color_subcountdown}} !important;
  }
</style>  


{% schema %}
{
  "name": "VIDEO COUNTDOWN V1",
  "class": "index-section",
  "settings": [
    {
      "type": "header",
      "content": "Video"
    },
    {
      "type": "image_picker",
      "id": "video_img",
      "info": "800 x 800px recommended",
      "label": "Video Image"
    },
    {
      "type": "url",
      "id": "url_video1",
      "label": "URL Video",
      "info": "[Upload video .mp4 in here](/admin/settings/files)"
    },
    {
      "type": "header",
      "content": "Countdown"
    },
    {
      "type": "text",
      "id": "title_info",
      "label": "Title info",
      "default": "Deal Off The Day"
    },
	{
      "type": "color",
      "id": "color_title_info",
      "label": "Color Title info"
    },
    {
      "type": "header",
      "content": "Section Space"
    },
    {
      "type": "text",
      "id": "margin_top",
      "label": "Margin Top",
      "info": "Defined in pixels. Do not add the 'px' unit."
    },
    {
      "type": "text",
      "id": "margin_bottom",
      "label": "Margin Bottom",
      "info": "Defined in pixels. Do not add the 'px' unit."
    }
  ],
  "blocks": [
    {
      "type": "countdown",
	  "limit": 2,
      "name": "Countdown",
      "settings": [
        {
          "type": "header",
          "content": "Countdown Item"
        },
        {
          "type": "product",
          "id": "select_pd",
          "label": "Select Product"
        },
        {
          "type": "checkbox",
          "id": "enable_label_pd",
          "label": "Enable Label",
          "default": true
        },
        {
          "type": "text",
          "id": "timer",
          "label": "End date",
          "default": "2023-12-12-12-12-12",
          "info": "format datetime YYYY-MM-DD-hh-mm-ss"
        },
        {
          "type": "text",
          "id": "btn_name",
          "label": "Button Name",
          "default": "Buy Now"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "VIDEO COUNTDOWN V1",
      "category": "HOME",
      "blocks": [
        {
          "type": "countdown",
          "settings": {
            
          }
        },
        {
          "type": "countdown",
          "settings": {
            
          }
        }
      ]
    }
  ]
}
{% endschema %}


{% stylesheet %}
{% endstylesheet %}

