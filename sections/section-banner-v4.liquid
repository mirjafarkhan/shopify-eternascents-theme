<div data-section-id="{{ section.id }}" data-section-type="section-banner-v4" style="{% if section.settings.margin_top != blank %}margin-top: {{section.settings.margin_top}}px;{%endif%} {% if section.settings.margin_bottom != blank %}margin-bottom: {{section.settings.margin_bottom}}px;{% endif %}">
  <div class="section-banner-v4 mt-all">
    <div class="container container-v2">
      <div class="heading text-center">
        {% if section.settings.title_heading != blank %}
        <div class="title-heading">
          <h3>
            {{ section.settings.title_heading }}
          </h3>
        </div>
        {% endif %}
        {% if section.settings.subtitle_heading != blank %}
        <div class="subtitle-heading">
          <h4 style="color: {{ section.settings.color_subtitle_heading }}">
            {{ section.settings.subtitle_heading }}
          </h4>
        </div>
        {% endif %}
      </div>
      <div class="row">      
        <div class="col-lg-4 col-md-4 col-12 col-sm-12">
          <div class="banner-ver">
            <div class="banner-item">
              <a href="{{section.settings.url_button_banner1}}" class="box-img d-block">
                {% if section.settings.banner_img1 != blank %}
                <img data-src="{{section.settings.banner_img1 | img_url: 'master'}}" class="lazyload img-fluid w-100" alt="_img">
                {% else %}
                <img data-src="//via.placeholder.com/800x751" class="lazyload img-fluid w-100" alt="_img">
                {% endif %}
              </a>
              <div class="content">
                {% if section.settings.title_banner1 != blank %}
                <h3 class="title-banner" style="color: {{ section.settings.color_title }}">
                  {{section.settings.title_banner1}}
                </h3>
                {% endif %}

                {% if section.settings.desc1 != blank %}
                <p style="color: {{ section.settings.color_desc }}">
                  {{ section.settings.desc1 }}
                </p>
                {% endif %}

                {% if section.settings.button_1 != blank %}
                <a href="{{section.settings.url_button1}}" class="button-main1">
                  {{section.settings.button_1}}
                </a>
                {% endif %}

              </div>
            </div>
          </div>
        </div>    
        <div class="col-lg-4 col-md-4 col-12 col-sm-12">
          <div class="banner-ver">
            <div class="banner-item">
              <a href="{{section.settings.url_button_banner2}}" class="box-img d-block">
                {% if section.settings.banner_img2 != blank %}
                <img data-src="{{section.settings.banner_img2 | img_url: 'master'}}" class="lazyload img-fluid w-100" alt="_img">
                {% else %}
                <img data-src="//via.placeholder.com/800x751" class="lazyload img-fluid w-100" alt="_img">
                {% endif %}
              </a>
              <div class="content">
                {% if section.settings.title_banner2 != blank %}
                <h3 class="title-banner" style="color: {{ section.settings.color_title }}">
                  {{section.settings.title_banner2}}
                </h3>
                {% endif %}

                {% if section.settings.desc2 != blank %}
                <p style="color: {{ section.settings.color_desc }}">
                  {{ section.settings.desc2 }}
                </p>
                {% endif %}

                {% if section.settings.button_2 != blank %}
                <a href="{{section.settings.url_button2}}" class="button-main1">
                  {{section.settings.button_2}}
                </a>
                {% endif %}

              </div>
            </div>
          </div>
        </div>    
        <div class="col-lg-4 col-md-4 col-12 col-sm-12">
          <div class="banner-ver">
            <div class="banner-item">
              <a href="{{section.settings.url_button_banner3}}" class="box-img d-block">
                {% if section.settings.banner_img3 != blank %}
                <img data-src="{{section.settings.banner_img3 | img_url: 'master'}}" class="lazyload img-fluid w-100" alt="_img">
                {% else %}
                <img data-src="//via.placeholder.com/800x751" class="lazyload img-fluid w-100" alt="_img">
                {% endif %}
              </a>
              <div class="content">
                {% if section.settings.title_banner3 != blank %}
                <h3 class="title-banner" style="color: {{ section.settings.color_title }}">
                  {{section.settings.title_banner3}}
                </h3>
                {% endif %}

                {% if section.settings.desc3 != blank %}
                <p style="color: {{ section.settings.color_desc }}">
                  {{ section.settings.desc3 }}
                </p>
                {% endif %}

                {% if section.settings.button_3 != blank %}
                <a href="{{section.settings.url_button3}}" class="button-main1">
                  {{section.settings.button_3}}
                </a>
                {% endif %}

              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
<style>
  .section-banner-v4 .heading .title-heading h3 {
    -webkit-text-stroke-color: {{ section.settings.color_title_heading }};
    stroke: {{ section.settings.color_title_heading }};
  }
  .section-banner-v4 .banner-item .content .button-main1 {
    color: {{section.settings.color_button}};
    background-color: {{section.settings.bg_color_button}};
  }
  .section-banner-v4 .banner-item .content .button-main1:hover {
    color: {{section.settings.color_button_hover}};
    background-color: {{section.settings.bg_button_hover}};
  }
</style>

