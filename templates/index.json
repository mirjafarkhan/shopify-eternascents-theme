      "settings": {
        "eyebrow": "Our Story",
        "heading": "Why Choose Eterna Scents?",
        "lead": "We bring the finest Arabian perfumery directly from Dubai, Riyadh and the Gulf to your home in the UK.",
        "body": "<p>Every bottle in our collection is sourced directly from the most respected Arabian fragrance houses. From the smoky depth of pure oud to the floral warmth of Taif rose — we carry only authentic, premium fragrances that tell a story.</p><p>Whether you're searching for a long-lasting signature scent, a luxurious gift for men or women, or exploring the world of Arabic perfumery for the first time, Eterna Scents is your trusted guide.</p>",
        "stat1_number": "200+",
        "stat1_label": "Premium Fragrances",
        "cta_label": "Our Full Story",
        "cta_url": "/pages/about",
        "image_side": "right",
        "bg_color": "#ffffff",
        "gold_color": "#C9A646",
        "navy_color": "#071321"
      }
